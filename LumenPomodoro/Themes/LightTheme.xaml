<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Font Families (Inter — DESIGN.md open-source substitute for SF Pro) -->
    <FontFamily x:Key="InterLight">pack://application:,,,/Fonts/#Inter Light</FontFamily>
    <FontFamily x:Key="InterRegular">pack://application:,,,/Fonts/#Inter</FontFamily>
    <FontFamily x:Key="InterSemiBold">pack://application:,,,/Fonts/#Inter SemiBold</FontFamily>

    <!-- Light Theme Colors (DESIGN.md token mapping) -->
    <Color x:Key="PrimaryColor">#0066CC</Color>
    <Color x:Key="PrimaryHoverColor">#0071E3</Color>
    <Color x:Key="SuccessColor">#34C759</Color>
    <Color x:Key="WarningColor">#FF9F0A</Color>
    <Color x:Key="ErrorColor">#FF3B30</Color>

    <!-- Background Colors -->
    <Color x:Key="WindowBackgroundColor">#00000000</Color>
    <Color x:Key="GlassBackgroundColor">#F5F5F7</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <Color x:Key="ControlBackgroundColor">#D2D2D7</Color>
    <Color x:Key="SurfacePearlColor">#FAFAFC</Color>

    <!-- Text Colors -->
    <Color x:Key="PrimaryTextColor">#1D1D1F</Color>
    <Color x:Key="SecondaryTextColor">#7A7A7A</Color>
    <Color x:Key="TertiaryTextColor">#CCCCCC</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderColor">#E0E0E0</Color>
    <Color x:Key="BorderHoverColor">#D2D2D7</Color>

    <!-- Brush Resources -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="GlassBackgroundBrush" Color="{StaticResource GlassBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{StaticResource ControlBackgroundColor}" />
    <SolidColorBrush x:Key="SurfacePearlBrush" Color="{StaticResource SurfacePearlColor}" />

    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="{StaticResource TertiaryTextColor}" />

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHoverColor}" />

</ResourceDictionary>
