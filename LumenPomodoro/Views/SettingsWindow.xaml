<Window x:Class="LumenPomodoro.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:LumenPomodoro.Models"
        mc:Ignorable="d"
        Title="设置" Height="600" Width="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Closing="Window_Closing">
    
    <Window.Resources>
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource GlassBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Color="{DynamicResource PrimaryTextColor}" Opacity="0.15" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Margin" Value="0,16,0,8" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Margin" Value="0,8,0,4" />
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="ToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{DynamicResource BorderBrush}">
                            <Ellipse x:Name="Thumb" Fill="White" Width="20" Height="20" Margin="2"
                                     HorizontalAlignment="Left" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup Name="CheckStates">
                                    <VisualState Name="Checked">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(Fill).(SolidColorBrush.Color)" To="#3B82F6" />
                                            <ThicknessAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="Margin" To="26,2,2,2" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState Name="Unchecked">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(Fill).(SolidColorBrush.Color)" To="White" />
                                            <ThicknessAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="Margin" To="2,2,2,2" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Border Style="{StaticResource GlassPanel}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButton}" Width="32" Height="32" Padding="0" Click="CloseButton_Click">
                        <TextBlock Text="&#xE92B;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                </StackPanel>
                
                <TextBlock Grid.Row="1" Text="设置" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,16,0,0" />
                
                <StackPanel Grid.Row="2">
                    <TextBlock Text="计时设置" Style="{StaticResource SectionHeader}" />
                    
                    <Label Content="专注时间（分钟）" Style="{StaticResource LabelStyle}" />
                    <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding WorkMinutes, UpdateSourceTrigger=PropertyChanged}" />

                    <Label Content="短休息时间（分钟）" Style="{StaticResource LabelStyle}" />
                    <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding ShortBreakMinutes, UpdateSourceTrigger=PropertyChanged}" />

                    <Label Content="长休息时间（分钟）" Style="{StaticResource LabelStyle}" />
                    <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding LongBreakMinutes, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                
                <StackPanel Grid.Row="3">
                    <TextBlock Text="摄像头提醒" Style="{StaticResource SectionHeader}" />
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ToggleButton Style="{StaticResource ToggleStyle}" IsChecked="{Binding CameraAlertEnabled}" />
                        <Label Content="启用摄像头提醒" Style="{StaticResource LabelStyle}" Margin="8,8,0,4" />
                    </StackPanel>
                    
                    <Label Content="提醒模式" Style="{StaticResource LabelStyle}" />
                    <ComboBox Style="{StaticResource ComboBoxStyle}" SelectedValue="{Binding CameraAlertMode}" SelectedValuePath="Tag">
                        <ComboBoxItem Content="固定时长" Tag="{x:Static models:CameraAlertMode.FixedDuration}" />
                        <ComboBoxItem Content="直到确认" Tag="{x:Static models:CameraAlertMode.UntilConfirm}" />
                        <ComboBoxItem Content="跟随休息" Tag="{x:Static models:CameraAlertMode.FollowBreak}" />
                    </ComboBox>
                    
                    <Label Content="固定亮灯时长（秒）" Style="{StaticResource LabelStyle}" />
                    <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding CameraFixedOnSeconds, UpdateSourceTrigger=PropertyChanged}" />
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ToggleButton Style="{StaticResource ToggleStyle}" IsChecked="{Binding CameraFollowBreakEnabled}" />
                        <Label Content="休息期间亮灯" Style="{StaticResource LabelStyle}" Margin="8,8,0,4" />
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ToggleButton Style="{StaticResource ToggleStyle}" IsChecked="{Binding CameraAlertCanManualClose}" />
                        <Label Content="提醒中允许手动关闭" Style="{StaticResource LabelStyle}" Margin="8,8,0,4" />
                    </StackPanel>
                    
                    <Label Content="摄像头选择" Style="{StaticResource LabelStyle}" />
                    <ComboBox Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding AvailableCameras}" 
                              SelectedIndex="{Binding SelectedCameraIndex}" />
                    
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Click="TestCameraButton_Click">
                            测试摄像头
                        </Button>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Row="4">
                    <TextBlock Text="提醒方式" Style="{StaticResource SectionHeader}" />
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ToggleButton Style="{StaticResource ToggleStyle}" IsChecked="{Binding SoundEnabled}" />
                        <Label Content="声音提醒" Style="{StaticResource LabelStyle}" Margin="8,8,0,4" />
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ToggleButton Style="{StaticResource ToggleStyle}" IsChecked="{Binding PopupEnabled}" />
                        <Label Content="弹窗提醒" Style="{StaticResource LabelStyle}" Margin="8,8,0,4" />
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ToggleButton Style="{StaticResource ToggleStyle}" IsChecked="{Binding SystemNotificationEnabled}" />
                        <Label Content="系统通知" Style="{StaticResource LabelStyle}" Margin="8,8,0,4" />
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Row="5">
                    <TextBlock Text="窗口设置" Style="{StaticResource SectionHeader}" />
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ToggleButton Style="{StaticResource ToggleStyle}" IsChecked="{Binding TrayEnabled}" />
                        <Label Content="托盘运行" Style="{StaticResource LabelStyle}" Margin="8,8,0,4" />
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ToggleButton Style="{StaticResource ToggleStyle}" IsChecked="{Binding CloseToTray}" />
                        <Label Content="关闭时最小化到托盘" Style="{StaticResource LabelStyle}" Margin="8,8,0,4" />
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ToggleButton Style="{StaticResource ToggleStyle}" IsChecked="{Binding AutoStartEnabled}" />
                        <Label Content="开机自启" Style="{StaticResource LabelStyle}" Margin="8,8,0,4" />
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Row="6">
                    <TextBlock Text="外观" Style="{StaticResource SectionHeader}" />
                    
                    <Label Content="主题" Style="{StaticResource LabelStyle}" />
                    <ComboBox Style="{StaticResource ComboBoxStyle}" SelectedValue="{Binding Theme}" SelectedValuePath="Tag">
                        <ComboBoxItem Content="跟随系统" Tag="system" />
                        <ComboBoxItem Content="浅色" Tag="light" />
                        <ComboBoxItem Content="深色" Tag="dark" />
                    </ComboBox>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ToggleButton Style="{StaticResource ToggleStyle}" IsChecked="{Binding AnimationEnabled}" />
                        <Label Content="启用动画" Style="{StaticResource LabelStyle}" Margin="8,8,0,4" />
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                    <Button Style="{StaticResource SecondaryButton}" Click="CloseButton_Click">
                        取消
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}" Click="SaveButton_Click">
                        保存
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

