<Window x:Class="LumenPomodoro.Views.FocusCompleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="专注完成"
        Width="400"
        Height="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="CenterOwner">
    <!-- DESIGN.md rounded.lg = 18, no shadow on UI chrome -->
    <Border Background="{DynamicResource GlassBackgroundBrush}"
            CornerRadius="18">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Ellipse Grid.Row="0" Width="64" Height="64" Fill="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" Margin="0,0,0,16" />
            <Path Grid.Row="0" Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Fill="White"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,16"
                  Width="32" Height="32" Stretch="Uniform" />

            <!-- DESIGN.md tagline = 21/600 -->
            <TextBlock Grid.Row="1"
                       Text="专注完成！"
                       FontSize="21"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />

            <TextBlock x:Name="SuggestionText" Grid.Row="2"
                       FontSize="14"
                       Foreground="{DynamicResource WarningBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"
                       Margin="0,0,0,8" />

            <!-- DESIGN.md body = 17/400 -->
            <TextBlock Grid.Row="3"
                       Text="您已完成本轮专注，现在该休息一下了。建议起身活动、喝水或做些简单的伸展运动。"
                       FontSize="17"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,0,0,16" />

            <!-- DESIGN.md buttons = pill, caption = 14/400 -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button Content="开始短休息"
                        Padding="22,11"
                        Background="{DynamicResource SuccessBrush}"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="Normal"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="StartBreak_Click"
                        Margin="0,0,8,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="9999" />
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="LongBreakButton" Content="长休息"
                        Padding="22,11"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="Normal"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="StartLongBreak_Click"
                        Visibility="Collapsed"
                        Margin="0,0,8,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="9999" />
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="稍后休息"
                        Padding="22,11"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        FontSize="14"
                        FontWeight="Normal"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="LaterBreak_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="9999" />
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
