<Window x:Class="LumenPomodoro.Views.BreakCompleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="休息完成"
        Width="400"
        Height="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="CenterOwner">
    <!-- DESIGN.md rounded.lg = 18, no shadow on UI chrome -->
    <Border Background="{DynamicResource GlassBackgroundBrush}"
            CornerRadius="18">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Ellipse Grid.Row="0" Width="64" Height="64" Fill="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,16" />
            <Path Grid.Row="0" Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Fill="White"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,16"
                  Width="32" Height="32" Stretch="Uniform" />

            <!-- DESIGN.md tagline = 21/600 -->
            <TextBlock Grid.Row="1"
                       Text="休息完成！"
                       FontSize="21"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />

            <!-- DESIGN.md body = 17/400 -->
            <TextBlock Grid.Row="2"
                       Text="休息结束了，准备好开始下一轮专注了吗？保持专注，继续加油！"
                       FontSize="17"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,0,0,16" />

            <!-- DESIGN.md buttons = pill, caption = 14/400 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button Content="开始下一轮"
                        Padding="22,11"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="Normal"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="StartNext_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="9999" />
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
