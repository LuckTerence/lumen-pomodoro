<Window x:Class="LumenPomodoro.Views.DailyReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="昨日学习报告"
        Width="380" Height="Auto" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        Topmost="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <FontFamily x:Key="NumberFont">Consolas</FontFamily>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Border Background="{DynamicResource SpotifySurface1Brush}" CornerRadius="16"
                Padding="0" Margin="16" MaxWidth="420">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="24" Opacity="0.4" Color="#000000"/>
            </Border.Effect>
            <StackPanel>
                <Border Height="3" Background="{StaticResource AccentBaseBrush}" CornerRadius="16,16,0,0" />

                <StackPanel Margin="24,20,24,0">
                    <TextBlock Text="昨日学习报告" FontSize="17" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"
                               Foreground="{DynamicResource SpotifyTextPrimaryBrush}" />
                    <TextBlock x:Name="DateText" FontSize="13" Foreground="{DynamicResource SpotifyTextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,20" />

                    <Border Background="{DynamicResource SpotifySurface2Brush}" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Rectangle Grid.Column="1" Fill="{DynamicResource SpotifyDividerBrush}" Width="1"
                                       VerticalAlignment="Stretch" Margin="0,8" Opacity="0.5" />

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock x:Name="PomodoroCountText" FontSize="40" FontWeight="SemiBold"
                                           FontFamily="{StaticResource NumberFont}"
                                           Foreground="{StaticResource AccentBaseBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="番茄钟" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SpotifyTextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock x:Name="MinutesText" FontSize="40" FontWeight="SemiBold"
                                           FontFamily="{StaticResource NumberFont}"
                                           Foreground="{StaticResource AccentBaseBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="专注分钟" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SpotifyTextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource SpotifySurface2Brush}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="主要学习内容" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SpotifyTextSecondaryBrush}" />
                            <TextBlock x:Name="MainTaskText" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SpotifyTextPrimaryBrush}"
                                       Margin="0,8,0,0" TextWrapping="Wrap" />
                            <Border Background="{DynamicResource SpotifySurface3Brush}" CornerRadius="6"
                                    Padding="10,8" Margin="0,12,0,0">
                                <TextBlock x:Name="StreakText" FontSize="12"
                                           Foreground="{DynamicResource SpotifyTextSecondaryBrush}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="AchievementBadge" Background="{StaticResource WarningBrush}"
                            CornerRadius="12" Padding="16" Margin="0,0,0,16" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="AchievementIcon" FontSize="24" Margin="0,0,8,0" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="AchievementTitle" FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock x:Name="AchievementDesc" FontSize="11"
                                           Foreground="{StaticResource StarBrush}" Opacity="0.9" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SpotifySurface2Brush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="学习统计" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SpotifyTextSecondaryBrush}" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,4">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBaseBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock x:Name="FocusSessionsText" FontSize="12"
                                               Foreground="{DynamicResource SpotifyTextTertiaryBrush}"
                                               Text="完成专注会话: --" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,4">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource InfoBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock x:Name="AvgQualityText" FontSize="12"
                                               Foreground="{DynamicResource SpotifyTextTertiaryBrush}"
                                               Text="平均质量: --" />
                                </StackPanel>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,4,0,0">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource DangerBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock x:Name="TotalTasksText" FontSize="12"
                                               Foreground="{DynamicResource SpotifyTextTertiaryBrush}"
                                               Text="完成科目: --" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,0">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource InfoBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock x:Name="BestStreakText" FontSize="12"
                                               Foreground="{DynamicResource SpotifyTextTertiaryBrush}"
                                               Text="当日连击: --" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SpotifySurface2Brush}" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                        <TextBlock x:Name="EncouragementText" FontSize="13" FontStyle="Italic"
                                   Foreground="{DynamicResource SpotifyTextSecondaryBrush}" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center" />
                    </Border>

                    <Border Background="{DynamicResource SpotifySurface2Brush}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                        <TextBlock x:Name="CategorySuggestionText" FontSize="13"
                                   Foreground="{StaticResource AccentBaseBrush}" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center" />
                    </Border>

                    <Button Style="{StaticResource SpotifyPillButton}" Click="Close_Click"
                            HorizontalAlignment="Center" Padding="40,12" MinWidth="140"
                            Background="{StaticResource AccentBaseBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="继续学习" FontSize="15" FontWeight="Bold" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>