<Window x:Class="LumenPomodoro.Views.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="今日统计"
        Height="520" Width="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <!-- DESIGN.md rounded.lg = 18, no shadow on UI chrome -->
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource GlassBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <!-- DESIGN.md store-utility-card = rounded.lg, padding 24 -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <!-- DESIGN.md button-utility = 14/400, no weight 500 -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid>
        <Border Style="{StaticResource GlassPanel}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Style="{StaticResource SecondaryButton}" Width="32" Height="32" Padding="0" Click="CloseButton_Click">
                        <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" Width="10" Height="10" />
                    </Button>
                </StackPanel>

                <!-- DESIGN.md display-md = 34/600 -->
                <TextBlock Grid.Row="1" Text="今日统计" FontSize="34" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,17,0,16" />

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Border Style="{StaticResource StatCard}" Margin="0,0,12,0" Width="160">
                        <StackPanel HorizontalAlignment="Center">
                            <!-- DESIGN.md display-lg = 40/600 -->
                            <TextBlock x:Name="PomodoroCountText" Text="0" FontSize="40" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="完成番茄钟" FontSize="14"
                                       Foreground="{DynamicResource TertiaryTextBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Width="160">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="FocusMinutesText" Text="0" FontSize="40" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="专注时长(分)" FontSize="14"
                                       Foreground="{DynamicResource TertiaryTextBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- DESIGN.md caption-strong = 14/600 -->
                <TextBlock Grid.Row="3" Text="按任务分布" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8" />

                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TaskStatsPanel" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
