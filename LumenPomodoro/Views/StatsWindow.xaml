<Window x:Class="LumenPomodoro.Views.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="今日统计"
        Height="480" Width="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource GlassBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <!-- Stat card: store-utility-card = rounded.lg = 18, padding 24 -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="24" />
        </Style>
    </Window.Resources>

    <Grid>
        <Border Style="{StaticResource GlassPanel}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Window controls -->
                <Grid Grid.Row="0" HorizontalAlignment="Right">
                    <Button Width="28" Height="28" Padding="0" Click="CloseButton_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Path Data="M7,7 L17,17 M17,7 L7,17" Stroke="{DynamicResource TertiaryTextBrush}" StrokeThickness="1.5"
                              Width="24" Height="24" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Button>
                </Grid>

                <!-- Title: tagline = 21/600 -->
                <TextBlock Grid.Row="1" Text="今日统计" FontSize="21" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,17,0,16" />

                <!-- Stats cards -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Border Style="{StaticResource StatCard}" Margin="0,0,12,0" Width="160">
                        <StackPanel HorizontalAlignment="Center">
                            <!-- display-lg = 40/600 -->
                            <TextBlock x:Name="PomodoroCountText" Text="0" FontSize="40" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="完成番茄钟" FontSize="14"
                                       Foreground="{DynamicResource TertiaryTextBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Width="160">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="FocusMinutesText" Text="0" FontSize="40" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="专注时长(分)" FontSize="14"
                                       Foreground="{DynamicResource TertiaryTextBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Section header: caption-strong = 14/600 -->
                <TextBlock Grid.Row="3" Text="按任务分布" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8" />

                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TaskStatsPanel" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
