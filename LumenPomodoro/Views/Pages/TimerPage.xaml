<Page x:Class="LumenPomodoro.Views.Pages.TimerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:LumenPomodoro.Converters"
      xmlns:controls="clr-namespace:LumenPomodoro.Controls"
      xmlns:local="clr-namespace:LumenPomodoro.Views.Pages"
      ScrollViewer.CanContentScroll="False"
      Background="Transparent">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:StatusToVisibilityConverter x:Key="StatusToVisibilityConverter" />
            <converters:StatusConverter x:Key="StatusConverter" />
            <converters:ZeroToCollapsedConverter x:Key="ZeroToCollapsedConverter" />
        </ResourceDictionary>
    </Page.Resources>

    <Page.InputBindings>
        <KeyBinding Key="Space" Command="{x:Static local:TimerPage.ToggleCommand}" />
        <KeyBinding Key="Escape" Command="{x:Static local:TimerPage.ResetCommand}" />
    </Page.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 任务选择 -->
            <RowDefinition Height="*" />      <!-- 核心区域 -->
        </Grid.RowDefinitions>

        <!-- ===== 任务选择（药丸形） ===== -->
        <Border Grid.Row="0" HorizontalAlignment="Center" Margin="0,16,0,0"
                Background="#3327272A" CornerRadius="20" Padding="16,8"
                Cursor="Hand" PreviewMouseDown="TaskName_MouseDown"
                Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Idle}">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="{Binding SelectedTask.Color, FallbackValue=#6A6A6A}" />
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock FontSize="13" Foreground="#B3FFFFFF" VerticalAlignment="Center">
                    <Run Text="{Binding SelectedTask.Name, Mode=OneWay, FallbackValue='选择任务'}" />
                    <Run Text="  ▾" FontSize="10" Foreground="#66FFFFFF" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ===== 核心计时区 ===== -->
        <StackPanel Grid.Row="1" Width="240" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- 专注中任务名 -->
                <TextBlock FontSize="12" Foreground="#789B9B9B"
                           HorizontalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Focus}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Paused}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="正在专注 · " />
                    <Run Text="{Binding SelectedTask.Name, Mode=OneWay, FallbackValue='未知任务'}" />
                </TextBlock>

                <!-- 状态标签 -->
                <TextBlock x:Name="StateLabelBlock"
                           Text="{Binding CurrentStatus, Converter={StaticResource StatusConverter}}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           FontSize="13" FontWeight="SemiBold" Foreground="#6B7280"
                           Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Idle}" />

                <!-- 圆环进度 + 计时器数字 -->
                <Grid Width="240" Height="240">
                    <controls:ArcProgress x:Name="ProgressRing" Progress="{Binding Progress}" StrokeThickness="4"
                                          ForegroundArcBrush="{StaticResource AccentBaseBrush}"
                                          BackgroundArcBrush="{StaticResource SurfaceOverlayBrush}" />
                    <TextBlock x:Name="TimerTextBlock" Text="{Binding RemainingTime}"
                               FontSize="72" FontWeight="Light" FontFamily="Consolas"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Grid>

                <!-- ===== 操作按钮区 ===== -->
                <Grid Width="240" Margin="0,24,0,0" HorizontalAlignment="Center">
                    <!-- 空闲状态：播放按钮 -->
                    <StackPanel x:Name="IdlePanel" Orientation="Vertical" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Idle}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFocusCompleted}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- 播放按钮 -->
                        <Button x:Name="PlayButton" Click="StartFocusButton_Click" Style="{StaticResource CircularPlayButton}" />

                        <!-- 预设快速切换 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,4">
                            <Button Click="PresetStandard_Click" Width="52" Height="28" Cursor="Hand" Style="{StaticResource Chip}"
                                    ToolTip="标准 25/5/15">
                                <TextBlock Text="标准" FontSize="11" />
                            </Button>
                            <Button Click="PresetDeep_Click" Width="52" Height="28" Cursor="Hand" Style="{StaticResource Chip}"
                                    Margin="6,0,6,0" ToolTip="深度工作 50/10/20">
                                <TextBlock Text="深度" FontSize="11" />
                            </Button>
                            <Button Click="PresetSprint_Click" Width="52" Height="28" Cursor="Hand" Style="{StaticResource Chip}"
                                    ToolTip="冲刺 15/3/10">
                                <TextBlock Text="冲刺" FontSize="11" />
                            </Button>
                        </StackPanel>

                        <!-- 时间调整（轻量级） -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Button Click="AdjustTimeDown_Click" Width="32" Height="32" Cursor="Hand"
                                    Background="Transparent" BorderThickness="0" Opacity="0.6">
                                <TextBlock Text="-" FontSize="18" Foreground="#6B7280" />
                            </Button>
                            <TextBlock x:Name="StepLabel" FontSize="13" Foreground="#6B7280"
                                       VerticalAlignment="Center" Margin="8,0" />
                            <Button Click="AdjustTimeUp_Click" Width="32" Height="32" Cursor="Hand"
                                    Background="Transparent" BorderThickness="0" Opacity="0.6">
                                <TextBlock Text="+" FontSize="18" Foreground="#6B7280" />
                            </Button>
                        </StackPanel>
                        <Button x:Name="HelpButton" Click="HelpButton_Click" Width="28" Height="28"
                                HorizontalAlignment="Center" Margin="0,8,0,0" Cursor="Hand"
                                Background="Transparent" BorderThickness="0" Opacity="0.4"
                                ToolTip="快捷键帮助">
                            <TextBlock Text="?" FontSize="16" Foreground="#6B7280" />
                        </Button>
                    </StackPanel>

                    <!-- 专注中：暂停/重置 -->
                    <StackPanel x:Name="FocusPanel"
                                Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Focus}"
                                Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Click="PauseButton_Click" Padding="32,10" Cursor="Hand"
                                Background="{StaticResource SurfaceRaisedBrush}"
                                BorderBrush="{StaticResource DividerBrush}" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="24" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="暂停" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                        </Button>
                        <Button Click="ResetButton_Click" Style="{StaticResource TextButton}" Content="重置"
                                Margin="12,0,0,0" />
                    </StackPanel>

                    <!-- 暂停中：继续/重置 -->
                    <StackPanel x:Name="PausedPanel"
                                Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Paused}"
                                Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Click="ResumeButton_Click" Padding="32,10" Cursor="Hand"
                                Background="{StaticResource AccentBaseBrush}"
                                BorderBrush="{StaticResource AccentBaseBrush}" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="24" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="继续" FontSize="14" Foreground="{StaticResource TextOnAccentBrush}" />
                        </Button>
                        <Button Click="ResetButton_Click" Style="{StaticResource TextButton}" Content="重置"
                                Margin="12,0,0,0" />
                    </StackPanel>

                    <!-- 休息中：结束休息 -->
                    <StackPanel x:Name="BreakPanel"
                                Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Break}"
                                HorizontalAlignment="Center">
                        <Button Click="EndBreakButton_Click" Style="{StaticResource PrimaryButton}" Content="结束休息" />
                    </StackPanel>

                    <!-- 专注完成：开始休息 -->
                    <StackPanel x:Name="CompletedPanel" Orientation="Vertical" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsFocusCompleted}" Value="True" />
                                            <Condition Binding="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Idle}" Value="Visible" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- 完成摘要 -->
                        <TextBlock Text="{Binding LastCompletedSummary}"
                                   FontSize="14" Foreground="#B3FFFFFF"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"
                                   TextTrimming="CharacterEllipsis" />

                        <!-- 手动评分 1-5 星 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="评分 " FontSize="14" Foreground="#99FFFFFF" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <Button x:Name="Star1" Tag="1" Click="Star_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Content="☆" FontSize="24" Foreground="#FBBF24" Padding="2,0" />
                            <Button x:Name="Star2" Tag="2" Click="Star_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Content="☆" FontSize="24" Foreground="#FBBF24" Padding="2,0" />
                            <Button x:Name="Star3" Tag="3" Click="Star_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Content="☆" FontSize="24" Foreground="#FBBF24" Padding="2,0" />
                            <Button x:Name="Star4" Tag="4" Click="Star_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Content="☆" FontSize="24" Foreground="#FBBF24" Padding="2,0" />
                            <Button x:Name="Star5" Tag="5" Click="Star_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Content="☆" FontSize="24" Foreground="#FBBF24" Padding="2,0" />
                        </StackPanel>

                        <!-- 笔记输入 -->
                        <Border Background="#3327272A" CornerRadius="12" Padding="12,8" Margin="0,0,0,16" MaxWidth="280">
                            <TextBox Text="{Binding CurrentNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     FontSize="13" Foreground="#B3FFFFFF"
                                     MaxLength="200" />
                        </Border>

                        <!-- 开始休息按钮 -->
                        <Button x:Name="StartBreakButton" Click="StartShortBreakButton_Click"
                                Style="{StaticResource PrimaryButton}" Content="开始休息" Margin="0,0,0,8" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <Button x:Name="LongBreakButton" Click="StartLongBreakButton_Click" Padding="16,8" Cursor="Hand"
                                    Background="Transparent" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SuggestLongBreak}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource WarningSubtleBrush}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock FontSize="12" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold"
                                               Visibility="{Binding SuggestLongBreak, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Run Text="建议长休息（已完成 " />
                                        <Run Text="{Binding TodayCompletedCount}" />
                                        <Run Text=" 个番茄）" />
                                    </TextBlock>
                                    <TextBlock x:Name="LongBreakLabel" FontSize="12" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="长休息" />
                                                <Setter Property="Foreground" Value="#6B7280" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SuggestLongBreak}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                            <Button Click="SkipBreakButton_Click" Padding="16,8" Cursor="Hand"
                                    Background="Transparent" BorderThickness="0">
                                <TextBlock Text="跳过" FontSize="12" Foreground="#4B5563" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- ===== 底部统计信息 ===== -->
                    <StackPanel Width="240" Margin="0,24,0,0" HorizontalAlignment="Center">
                    <!-- 摄像头灯状态：仅高级选项开启时展示，避免干扰「岛主路径」 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12" MaxWidth="280"
                                Visibility="{Binding IsCameraAlertEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Ellipse x:Name="CameraAlertDot" Width="6" Height="6" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#4B5563" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCameraAlertActive}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="11" Foreground="#6B7280" VerticalAlignment="Center"
                                   Text="{Binding CameraStatusDisplay}" TextWrapping="Wrap" MaxWidth="220" />
                        <Button Click="StopCameraButton_Click" Padding="8,4" Margin="8,0,0,0" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"
                                Visibility="{Binding IsCameraAlertActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="关闭" FontSize="11" Foreground="#4B5563" />
                        </Button>
                    </StackPanel>

                    <!-- 今日统计 -->
                    <!-- 目标进度条 -->
                    <Grid Width="240" Margin="0,0,0,8">
                        <Border Background="#1A27272A" CornerRadius="2" Height="3">
                            <Border Width="{Binding TodayPomodoroBarWidth}"
                                    HorizontalAlignment="Left" CornerRadius="2"
                                    Background="{StaticResource AccentBaseBrush}" />
                        </Border>
                    </Grid>
                    <TextBlock FontSize="11" Foreground="#4B5563"
                               HorizontalAlignment="Center" Cursor="Hand" PreviewMouseDown="StatsSummary_MouseDown">
                        <Run Text="今日 " />
                        <Run Text="{Binding TodayStats.CompletedPomodoros}" Foreground="#6B7280" FontWeight="SemiBold" />
                        <Run Text="/" />
                        <Run Text="{Binding AppSettings.DailyTargetPomodoros}" Foreground="#6B7280" FontWeight="SemiBold" />
                        <Run Text=" · 专注 " />
                        <Run Text="{Binding TodayStats.TotalFocusMinutes}" Foreground="#6B7280" FontWeight="SemiBold" />
                        <Run Text=" 分" />
                    </TextBlock>

                    <!-- Streak 显示 -->
                    <TextBlock FontSize="11" Foreground="#4B5563"
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               Visibility="{Binding StreakDays, Converter={StaticResource ZeroToCollapsedConverter}}">
                        <Run Text="已连续专注 " />
                        <Run Text="{Binding StreakDays}" Foreground="#6B7280" FontWeight="SemiBold" />
                        <Run Text=" 天" />
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="#4B5563"
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               Text="没关系，今天重新开始"
                               Visibility="{Binding ShowStreakEncouragement, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <!-- 考试倒计时 -->
                    <TextBlock FontSize="12" Foreground="#6B7280"
                               HorizontalAlignment="Center" Margin="0,8,0,0"
                               Visibility="{Binding ExamCountdown, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Run Text="{Binding ExamName, Mode=OneWay}" />
                        <Run Text=" 倒计时 " />
                        <Run Text="{Binding DaysUntilExam, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource AccentBaseBrush}" />
                        <Run Text=" 天" />
                    </TextBlock>

                    <!-- 快捷键提示 -->
                    <TextBlock FontSize="10" Foreground="#3B3B3B"
                               HorizontalAlignment="Center" Margin="0,12,0,0">
                        <Run Text="空格 开始/暂停 · Esc 重置 · 1-9 切换任务" />
                    </TextBlock>
                </StackPanel>
        </StackPanel>
    </Grid>
</Page>
