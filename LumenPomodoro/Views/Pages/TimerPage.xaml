<Page x:Class="LumenPomodoro.Views.Pages.TimerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:LumenPomodoro.Converters"
      xmlns:controls="clr-namespace:LumenPomodoro.Controls"
      ScrollViewer.CanContentScroll="False">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:StatusToVisibilityConverter x:Key="StatusToVisibilityConverter" />
            <converters:StatusConverter x:Key="StatusConverter" />
            <converters:ZeroToCollapsedConverter x:Key="ZeroToCollapsedConverter" />
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 任务选择 Chip -->
        <Border Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,24"
                Background="{DynamicResource SpotifySurface2Brush}"
                CornerRadius="12" Padding="12,6" Cursor="Hand"
                PreviewMouseDown="TaskName_MouseDown"
                Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Idle}">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="{Binding SelectedTask.Color, FallbackValue={StaticResource FallbackTaskColor}}" />
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock FontSize="13" Foreground="{DynamicResource SpotifyTextSecondaryBrush}" VerticalAlignment="Center">
                    <Run Text="{Binding SelectedTask.Name, Mode=OneWay, FallbackValue='选择任务'}" />
                    <Run Text="  ▾" FontSize="10" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 状态标签 -->
        <TextBlock x:Name="StateLabelBlock" Grid.Row="2"
                   Text="{Binding CurrentStatus, Converter={StaticResource StatusConverter}}"
                   Margin="0,0,0,12"
                   Foreground="{DynamicResource SpotifyTextSecondaryBrush}">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource StateLabel}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Idle}" Value="Visible">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- 圆环进度 + 计时器数字 -->
        <Grid Grid.Row="3" HorizontalAlignment="Center" Margin="0,0,0,24" Width="260" Height="260">
            <controls:ArcProgress x:Name="ProgressRing" Progress="{Binding Progress}" StrokeThickness="6">
                <controls:ArcProgress.ForegroundArcBrush>
                    <SolidColorBrush Color="{Binding SelectedTask.Color, FallbackValue=#0078D4}" />
                </controls:ArcProgress.ForegroundArcBrush>
                <controls:ArcProgress.BackgroundArcBrush>
                    <SolidColorBrush Color="{StaticResource ArcBackgroundColor}" />
                </controls:ArcProgress.BackgroundArcBrush>
            </controls:ArcProgress>
            <TextBlock x:Name="TimerTextBlock" Text="{Binding RemainingTime}"
                       Style="{StaticResource TimerText}" FontSize="80"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </TextBlock.RenderTransform>
            </TextBlock>
        </Grid>

        <!-- 摄像头提醒 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16"
                    Visibility="{Binding IsCameraAlertActive, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Ellipse x:Name="CameraAlertDot" Width="8" Height="8" Fill="#F59E0B" Margin="0,0,8,0" />
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center">
                <Run Text="摄像头已开启，帮助你保持专注" />
            </TextBlock>
            <Button Style="{StaticResource SpotifyButton}" Click="StopCameraButton_Click" FontSize="12" Padding="8,4" Margin="8,0,0,0">
                关闭
            </Button>
        </StackPanel>

        <!-- 操作按钮区 -->
        <Grid Grid.Row="5">
            <StackPanel x:Name="IdlePanel" Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Idle}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFocusCompleted}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- 快速任务切换 -->
                <ComboBox x:Name="QuickTaskCombo"
                          ItemsSource="{Binding Tasks}"
                          SelectedItem="{Binding SelectedTask}"
                          DisplayMemberPath="Name"
                          MinWidth="200" Margin="0,0,0,16"
                          FontSize="13" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Button Style="{StaticResource SpotifyButton}" Click="AdjustTimeDown_Click" FontSize="14" Padding="10,4" Width="36" Height="36">-</Button>
                    <TextBlock x:Name="StepLabel" FontSize="15" Foreground="{DynamicResource SpotifyTextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="12,0" />
                    <Button Style="{StaticResource SpotifyButton}" Click="AdjustTimeUp_Click" FontSize="14" Padding="10,4" Width="36" Height="36">+</Button>
                </StackPanel>
                <Button Style="{StaticResource SpotifyPlayButton}" Click="StartFocusButton_Click">
                    <TextBlock Text="▶" FontSize="24" Foreground="Black" />
                </Button>
            </StackPanel>

            <StackPanel x:Name="FocusPanel"
                        Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Focus}"
                        Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Style="{StaticResource SpotifyButton}" Click="PauseButton_Click" Padding="16,8">暂停</Button>
                <Button Style="{StaticResource SpotifyButton}" Click="ResetButton_Click" Padding="16,8" Margin="12,0,0,0">重置</Button>
            </StackPanel>

            <StackPanel x:Name="PausedPanel"
                        Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Paused}"
                        Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Style="{StaticResource SpotifyPillButton}" Click="ResumeButton_Click" Padding="24,12">继续</Button>
                <Button Style="{StaticResource SpotifyButton}" Click="ResetButton_Click" Padding="16,8" Margin="12,0,0,0">重置</Button>
            </StackPanel>

            <StackPanel x:Name="BreakPanel"
                        Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Break}"
                        Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Style="{StaticResource SpotifyPillButton}" Click="EndBreakButton_Click" Padding="24,12">结束休息</Button>
            </StackPanel>

            <StackPanel x:Name="CompletedPanel" Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsFocusCompleted}" Value="True" />
                                    <Condition Binding="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Idle}" Value="Visible" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- 质量评分 -->
                <TextBlock FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,8"
                           Foreground="{DynamicResource SpotifyGreenBrush}"
                           Text="{Binding QualityStars}" />

                <!-- 笔记输入 -->
                <ui:TextBox x:Name="NotesBox"
                            Text="{Binding CurrentNotes, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="记录这轮做了什么（可选）"
                            MaxWidth="280" Margin="0,0,0,12"
                            FontSize="13" Padding="12,8"
                            AcceptsReturn="False" MaxLength="200" />

                <!-- 快速任务切换 -->
                <ComboBox ItemsSource="{Binding Tasks}"
                          SelectedItem="{Binding SelectedTask}"
                          DisplayMemberPath="Name"
                          MinWidth="200" Margin="0,0,0,12"
                          FontSize="13" />

                <Button x:Name="StartBreakButton" Style="{StaticResource SpotifyPillButton}" Click="StartShortBreakButton_Click" Padding="32,14">开始休息</Button>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <Button Style="{StaticResource SpotifyButton}" Click="StartLongBreakButton_Click" Padding="10,6">长休息</Button>
                    <Button Style="{StaticResource SpotifyButton}" Click="SkipBreakButton_Click" Padding="10,6" Margin="8,0,0,0" Foreground="{DynamicResource SpotifyTextTertiaryBrush}">跳过</Button>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- 底部统计摘要 + 考试倒计时 + 快捷键提示 -->
        <StackPanel Grid.Row="6" HorizontalAlignment="Center" Margin="0,20,0,0">
            <TextBlock FontSize="11" Foreground="{DynamicResource SpotifyTextTertiaryBrush}"
                       HorizontalAlignment="Center" Cursor="Hand" PreviewMouseDown="StatsSummary_MouseDown">
                <Run Text="今日 " />
                <Run Text="{Binding TodayStats.CompletedPomodoros}" Foreground="{DynamicResource SpotifyTextSecondaryBrush}" FontWeight="SemiBold" />
                <Run Text="/" />
                <Run Text="{Binding AppSettings.DailyTargetPomodoros}" Foreground="{DynamicResource SpotifyTextSecondaryBrush}" FontWeight="SemiBold" />
                <Run Text=" · 专注 " />
                <Run Text="{Binding TodayStats.TotalFocusMinutes}" Foreground="{DynamicResource SpotifyTextSecondaryBrush}" FontWeight="SemiBold" />
                <Run Text=" 分" />
            </TextBlock>

            <!-- Streak 显示 -->
            <TextBlock FontSize="11" Foreground="{DynamicResource SpotifyTextTertiaryBrush}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"
                       Visibility="{Binding StreakDays, Converter={StaticResource ZeroToCollapsedConverter}}">
                <Run Text="已连续专注 " />
                <Run Text="{Binding StreakDays}" Foreground="{DynamicResource SpotifyTextSecondaryBrush}" FontWeight="SemiBold" />
                <Run Text=" 天" />
            </TextBlock>
            <TextBlock FontSize="11" Foreground="{DynamicResource SpotifyTextTertiaryBrush}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"
                       Text="没关系，今天重新开始"
                       Visibility="{Binding ShowStreakEncouragement, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <TextBlock FontSize="12" Foreground="{DynamicResource SpotifyTextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"
                       Visibility="{Binding ExamCountdown, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Run Text="{Binding ExamName}" />
                <Run Text=" 倒计时 " />
                <Run Text="{Binding DaysUntilExam}" FontWeight="SemiBold" Foreground="{DynamicResource SpotifyGreenBrush}" />
                <Run Text=" 天" />
            </TextBlock>
            <TextBlock FontSize="11" Foreground="{DynamicResource SpotifyTextTertiaryBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0">
                <Run Text="空格 开始/暂停 · Esc 重置 · 1-9 切换任务" />
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>
