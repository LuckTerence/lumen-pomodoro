<Page x:Class="LumenPomodoro.Views.Pages.TasksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      ScrollViewer.CanContentScroll="False"
      Background="Transparent">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="任务管理" FontSize="21" FontWeight="SemiBold"
                   Foreground="White" Margin="0,0,0,20" />

        <!-- 添加任务 -->
        <Border Grid.Row="1" Background="#3327272A" CornerRadius="16" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <ui:TextBox x:Name="NewTaskNameBox" PlaceholderText="任务名称"
                         Background="#1A27272A" BorderBrush="#26FFFFFF" BorderThickness="1"
                         Foreground="#B3FFFFFF" Padding="12,8" FontSize="13"
                         Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="ColorComboBox" Width="120" Margin="0,0,8,0" SelectedIndex="0" />
                    <Button Click="AddTask_Click" Padding="20,8" Cursor="Hand">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#059669" Offset="0" />
                                <GradientStop Color="#34D399" Offset="1" />
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="16"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="添加" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 任务列表 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      x:Name="TasksScrollViewer">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Tasks.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <ItemsControl ItemsSource="{Binding Tasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="16,12"
                                Background="#3327272A" CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding Color}" />
                                    </Ellipse.Fill>
                                </Ellipse>

                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="14" FontWeight="Medium"
                                           Foreground="#B3FFFFFF" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Click="SelectTask_Click" Tag="{Binding Id}" Padding="12,6" Cursor="Hand"
                                            Background="#1A27272A" BorderBrush="#26FFFFFF" BorderThickness="1">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="12" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="选择" FontSize="12" Foreground="#B3FFFFFF" />
                                    </Button>
                                    <Button Click="EditTask_Click" Tag="{Binding Id}" Padding="12,6" Margin="6,0,0,0" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0">
                                        <TextBlock Text="编辑" FontSize="12" Foreground="#6B7280" />
                                    </Button>
                                    <Button Click="DeleteTask_Click" Tag="{Binding Id}" Padding="12,6" Margin="6,0,0,0" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0">
                                        <TextBlock Text="删除" FontSize="12" Foreground="#4B5563" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 空状态 -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Tasks.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="+" FontSize="36" Foreground="#4B5563" HorizontalAlignment="Center" Margin="0,0,0,12" />
            <TextBlock Text="还没有任务" FontSize="15" Foreground="#6B7280" HorizontalAlignment="Center" />
            <TextBlock Text="在下方添加你的第一个任务" FontSize="11" Foreground="#4B5563"
                       HorizontalAlignment="Center" Margin="0,4,0,0" />
        </StackPanel>
    </Grid>
</Page>
