<Page x:Class="LumenPomodoro.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:models="clr-namespace:LumenPomodoro.Models"
      ScrollViewer.CanContentScroll="False"
      Background="Transparent">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
        <StackPanel Margin="24,16,24,96" MaxWidth="560" HorizontalAlignment="Center">

            <!-- 标题 -->
            <TextBlock Text="设置" FontSize="21" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,20" />

            <!-- ===== 计时 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="计时" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" Margin="0,0,0,16" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="专注时间（分钟）" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="单次专注的时长，建议 25 分钟" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:NumberBox Grid.Column="1" Value="{Binding WorkMinutes, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="1" Maximum="120" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="短休息（分钟）" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="每次专注后的短暂休息" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:NumberBox Grid.Column="1" Value="{Binding ShortBreakMinutes, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="1" Maximum="60" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="长休息（分钟）" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="完成一轮番茄钟后的长休息" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:NumberBox Grid.Column="1" Value="{Binding LongBreakMinutes, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="1" Maximum="60" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="长休息间隔（次）" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="每完成几个番茄钟触发长休息" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:NumberBox Grid.Column="1" Value="{Binding LongBreakInterval, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="2" Maximum="10" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="每日目标（分钟）" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="每天专注的总分钟数目标" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:NumberBox Grid.Column="1" Value="{Binding DailyGoalMinutes, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="0" Maximum="1440" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="每周目标（分钟）" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="每周专注的总分钟数目标" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:NumberBox Grid.Column="1" Value="{Binding WeeklyGoalMinutes, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="0" Maximum="10080" VerticalAlignment="Center" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="每日目标（番茄钟数）" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="每天完成的番茄钟数量目标" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:NumberBox Grid.Column="1" Value="{Binding DailyTargetPomodoros, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="0" Maximum="50" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== 考试倒计时 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="考试倒计时" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" Margin="0,0,0,16" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="考试名称" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="显示在计时器页面的倒计时标题" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:TextBox Grid.Column="1" Text="{Binding ExamName, Mode=OneWay}" MinWidth="120" VerticalAlignment="Center"
                                    Padding="8,4" FontSize="13" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="考试日期" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="设置后自动计算剩余天数" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <DatePicker Grid.Column="1" SelectedDate="{Binding ExamDate}" MinWidth="150" VerticalAlignment="Center"
                                    FontSize="13" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== 防走神 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="防走神" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" Margin="0,0,0,16" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="启用防走神检测" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="专注期间监控前台窗口与键鼠空闲，分心或离开时提醒" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding FocusGuardEnabled}" VerticalAlignment="Center" />
                    </Grid>
                    <StackPanel Visibility="{Binding FocusGuardEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="离开判定时长（秒）" FontSize="13" Foreground="#B3FFFFFF" />
                                <TextBlock Text="键鼠无操作超过该时长判为离开" FontSize="11" Foreground="#6B7280" />
                            </StackPanel>
                            <ui:NumberBox Grid.Column="1" Value="{Binding FocusGuardIdleSeconds, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="10" Maximum="3600" />
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="提醒强度" FontSize="13" Foreground="#B3FFFFFF" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" Width="180"
                                      SelectedValue="{Binding FocusGuardAlertLevel}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="仅系统通知" Tag="{x:Static models:CameraAlertLevel.Light}" Foreground="#B3FFFFFF" Background="#3327272A" />
                                <ComboBoxItem Content="系统通知 + 提示音" Tag="{x:Static models:CameraAlertLevel.Medium}" Foreground="#B3FFFFFF" Background="#3327272A" />
                                <ComboBoxItem Content="系统通知 + 提示音 + 置顶" Tag="{x:Static models:CameraAlertLevel.Severe}" Foreground="#B3FFFFFF" Background="#3327272A" />
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="防抖次数" FontSize="13" Foreground="#B3FFFFFF" />
                                <TextBlock Text="连续命中几次后才提醒，减少误报" FontSize="11" Foreground="#6B7280" />
                            </StackPanel>
                            <ui:NumberBox Grid.Column="1" Value="{Binding FocusGuardDebounceHits, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="1" Maximum="10" />
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="每轮最多提醒" FontSize="13" Foreground="#B3FFFFFF" />
                                <TextBlock Text="单次专注会话内走神通知次数上限" FontSize="11" Foreground="#6B7280" />
                            </StackPanel>
                            <ui:NumberBox Grid.Column="1" Value="{Binding FocusGuardMaxAlertsPerSession, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="1" Maximum="20" />
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="遵从系统勿扰" FontSize="13" Foreground="#B3FFFFFF" />
                                <TextBlock Text="锁屏或通知关闭时不弹走神提醒（仍做检测）" FontSize="11" Foreground="#6B7280" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding FocusGuardRespectDoNotDisturb}" VerticalAlignment="Center" />
                        </Grid>
                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Text="分心 App 黑名单" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="每行一个关键词，匹配前台进程名或窗口标题（如 bilibili、微信、Steam）" FontSize="11" Foreground="#6B7280" Margin="0,0,0,6" />
                            <TextBox Text="{Binding FocusGuardBlocklistText, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" MaxHeight="160"
                                     VerticalScrollBarVisibility="Auto" FontSize="12"
                                     Foreground="#E6FFFFFF" Background="#22000000" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== 摄像头 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="摄像头" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" Margin="0,0,0,16" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="启用摄像头提醒" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="专注结束后点亮摄像头指示灯提醒休息" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CameraAlertEnabled}" VerticalAlignment="Center" />
                    </Grid>
                    <StackPanel Visibility="{Binding CameraAlertEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="提醒模式" FontSize="13" Foreground="#B3FFFFFF" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" Width="180"
                                      SelectedValue="{Binding CameraAlertMode}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="固定时长" Tag="{x:Static models:CameraAlertMode.FixedDuration}" Foreground="#B3FFFFFF" Background="#3327272A" />
                                <ComboBoxItem Content="直到确认" Tag="{x:Static models:CameraAlertMode.UntilConfirm}" Foreground="#B3FFFFFF" Background="#3327272A" />
                                <ComboBoxItem Content="跟随休息" Tag="{x:Static models:CameraAlertMode.FollowBreak}" Foreground="#B3FFFFFF" Background="#3327272A" />
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="固定亮灯时长（秒）" FontSize="13" Foreground="#B3FFFFFF" />
                            </StackPanel>
                            <ui:NumberBox Grid.Column="1" Value="{Binding CameraFixedOnSeconds, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="1" Maximum="300" />
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="休息期间亮灯" FontSize="13" Foreground="#B3FFFFFF" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CameraFollowBreakEnabled}" />
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="允许手动关闭" FontSize="13" Foreground="#B3FFFFFF" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CameraAlertCanManualClose}" />
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="提醒强度" FontSize="13" Foreground="#B3FFFFFF" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" Width="180"
                                      SelectedValue="{Binding CameraAlertLevel}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="仅指示灯" Tag="{x:Static models:CameraAlertLevel.Light}" Foreground="#B3FFFFFF" Background="#3327272A" />
                                <ComboBoxItem Content="指示灯 + 弹窗" Tag="{x:Static models:CameraAlertLevel.Medium}" Foreground="#B3FFFFFF" Background="#3327272A" />
                                <ComboBoxItem Content="指示灯 + 弹窗 + 置顶" Tag="{x:Static models:CameraAlertLevel.Severe}" Foreground="#B3FFFFFF" Background="#3327272A" />
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="防走神检测" FontSize="13" Foreground="#B3FFFFFF" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding PresenceDetectionEnabled}" />
                        </Grid>
                        <Grid Margin="0,0,0,14" Visibility="{Binding PresenceDetectionEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="离开检测时长（秒）" FontSize="13" Foreground="#B3FFFFFF" />
                            </StackPanel>
                            <ui:NumberBox Grid.Column="1" Value="{Binding PresenceDetectionSeconds, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="3" Maximum="30" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="摄像头选择" FontSize="13" Foreground="#B3FFFFFF" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" Width="180"
                                      ItemsSource="{Binding AvailableCameras}"
                                      SelectedIndex="{Binding SelectedCameraIndex}"
                                      Foreground="#B3FFFFFF" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== 提醒 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="提醒" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" Margin="0,0,0,16" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="声音提醒" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="专注/休息结束时播放提示音" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding SoundEnabled}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="弹窗提醒" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="专注/休息结束时弹出完成面板" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding PopupEnabled}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="系统通知" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="使用 Windows 通知中心提醒" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding SystemNotificationEnabled}" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== 外观 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="外观" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" Margin="0,0,0,16" />
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="动画效果" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="呼吸、缩放等过渡动画" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding AnimationEnabled}" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== 系统 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="系统" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" Margin="0,0,0,16" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="托盘运行" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="最小化后在系统托盘继续运行" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding TrayEnabled}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="关闭时最小化到托盘" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="点击关闭按钮时隐藏到托盘而非退出" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CloseToTray}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="开机自启" FontSize="13" Foreground="#B3FFFFFF" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoStartEnabled}" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="计时中退出需确认" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="专注或休息进行中关闭应用时弹出确认" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ConfirmExitWhileFocusing}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="结束前提醒（秒）" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="倒计时剩余该秒数时提醒一次；0 为关闭" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:NumberBox Grid.Column="1" Value="{Binding SessionEndPreNotifySeconds, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="0" Maximum="300" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="全屏休息" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="开始休息时覆盖全屏倒计时，减少继续工作的诱惑" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding FullscreenBreakEnabled}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="严格模式" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="禁止手动关摄像头灯、禁止提前结束休息；完成时强制置顶" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding StrictModeEnabled}" VerticalAlignment="Center" />
                    </Grid>
                    <Border Background="#22000000" CornerRadius="12" Padding="14" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="专注场景预设" FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0" />
                            <TextBlock Text="一键切换推荐组合；不改时长与任务。之后仍可逐项微调。"
                                       FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,4,0,12" />
                            <UniformGrid Columns="3" Margin="0,0,0,0">
                                <Button Content="轻松" Command="{Binding ApplyLightFocusPresetCommand}"
                                        Margin="0,0,6,0" Padding="8,8" Cursor="Hand"
                                        Background="#334155" Foreground="White" BorderThickness="0" />
                                <Button Content="标准" Command="{Binding ApplyStandardFocusPresetCommand}"
                                        Margin="3,0" Padding="8,8" Cursor="Hand"
                                        Background="#3B82F6" Foreground="White" BorderThickness="0" />
                                <Button Content="严格专注" Command="{Binding ApplyStrictFocusPresetCommand}"
                                        Margin="6,0,0,0" Padding="8,8" Cursor="Hand"
                                        Background="#7C3AED" Foreground="White" BorderThickness="0" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== 实验功能 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="实验功能" FontSize="14" FontWeight="SemiBold"
                               Foreground="#B3FFFFFF" Margin="0,0,0,4" />
                    <TextBlock Text="以下功能可以单独开关，关闭后相关数据和界面将被隐藏"
                               FontSize="11" Foreground="#4B5563" Margin="0,0,0,16" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="学习洞察" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="峰值时段、最优日、趋势分析、科目均衡等" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding InsightsEnabled}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="每日复盘报告" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="每天启动时展示昨日学习回顾" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding DailyReportEnabled}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="考试倒计时" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="主界面底部显示距离考试的剩余天数" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ExamCountdownEnabled}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="灵动岛通知" FontSize="13" Foreground="#B3FFFFFF" />
                            <TextBlock Text="窗口最小化时在屏幕角落显示浮动倒计时" FontSize="11" Foreground="#6B7280" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding DynamicIslandEnabled}" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 保存按钮 -->
            <Button Click="Save_Click" Padding="32,10" Cursor="Hand"
                    Background="{StaticResource AccentBaseBrush}"
                    BorderBrush="{StaticResource AccentBaseBrush}" BorderThickness="1"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="24" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock Text="保存" FontSize="14" Foreground="{StaticResource TextOnAccentBrush}" />
            </Button>
        </StackPanel>
    </ScrollViewer>
</Page>
