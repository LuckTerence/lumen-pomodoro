<Page x:Class="LumenPomodoro.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:models="clr-namespace:LumenPomodoro.Models"
      ScrollViewer.CanContentScroll="False">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="SettingsSection" TargetType="Border">
                <Setter Property="Margin" Value="0,0,0,16" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{DynamicResource SpotifySurface1Brush}" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
        <StackPanel Margin="24,24,24,96" MaxWidth="560" HorizontalAlignment="Center">
            <TextBlock Text="设置" Style="{StaticResource PageTitle}" Margin="0,0,0,16" />

            <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="计时" Style="{StaticResource SectionTitle}" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="专注时间（分钟）" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="单次专注的时长，建议 25 分钟" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:NumberBox Grid.Column="1" Value="{Binding WorkMinutes, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="1" Maximum="120" VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="短休息（分钟）" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="每次专注后的短暂休息" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:NumberBox Grid.Column="1" Value="{Binding ShortBreakMinutes, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="1" Maximum="60" VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="长休息（分钟）" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="完成一轮番茄钟后的长休息" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:NumberBox Grid.Column="1" Value="{Binding LongBreakMinutes, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="1" Maximum="60" VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="长休息间隔（次）" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="每完成几个番茄钟触发长休息" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:NumberBox Grid.Column="1" Value="{Binding LongBreakInterval, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="2" Maximum="10" VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="每日目标（分钟）" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="每天专注的总分钟数目标" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:NumberBox Grid.Column="1" Value="{Binding DailyGoalMinutes, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="0" Maximum="1440" VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="每周目标（分钟）" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="每周专注的总分钟数目标" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:NumberBox Grid.Column="1" Value="{Binding WeeklyGoalMinutes, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="0" Maximum="10080" VerticalAlignment="Center" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="每日目标（番茄钟数）" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="每天完成的番茄钟数量目标" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:NumberBox Grid.Column="1" Value="{Binding DailyTargetPomodoros, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="0" Maximum="50" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="考试倒计时" Style="{StaticResource SectionTitle}" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="考试名称" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="显示在计时器页面的倒计时标题" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <TextBox Grid.Column="1" Text="{Binding ExamName}" MinWidth="120" VerticalAlignment="Center" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="考试日期" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="设置后自动计算剩余天数" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <DatePicker Grid.Column="1" SelectedDate="{Binding ExamDate}" MinWidth="150" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="摄像头" Style="{StaticResource SectionTitle}" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="启用摄像头提醒" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="专注结束后点亮摄像头指示灯提醒休息" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CameraAlertEnabled}" VerticalAlignment="Center" />
                        </Grid>
                        <StackPanel Visibility="{Binding CameraAlertEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="提醒模式" Style="{StaticResource SettingLabel}" />
                                <ComboBox Grid.Column="1" Width="180"
                                          SelectedValue="{Binding CameraAlertMode}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="固定时长" Tag="{x:Static models:CameraAlertMode.FixedDuration}" />
                                    <ComboBoxItem Content="直到确认" Tag="{x:Static models:CameraAlertMode.UntilConfirm}" />
                                    <ComboBoxItem Content="跟随休息" Tag="{x:Static models:CameraAlertMode.FollowBreak}" />
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="固定亮灯时长（秒）" Style="{StaticResource SettingLabel}" />
                                <ui:NumberBox Grid.Column="1" Value="{Binding CameraFixedOnSeconds, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="1" Maximum="300" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="休息期间亮灯" Style="{StaticResource SettingLabel}" />
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CameraFollowBreakEnabled}" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="允许手动关闭" Style="{StaticResource SettingLabel}" />
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CameraAlertCanManualClose}" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="提醒强度" Style="{StaticResource SettingLabel}" />
                                <ComboBox Grid.Column="1" Width="180"
                                          SelectedValue="{Binding CameraAlertLevel}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="仅指示灯" Tag="{x:Static models:CameraAlertLevel.Light}" />
                                    <ComboBoxItem Content="指示灯 + 弹窗" Tag="{x:Static models:CameraAlertLevel.Medium}" />
                                    <ComboBoxItem Content="指示灯 + 弹窗 + 置顶" Tag="{x:Static models:CameraAlertLevel.Severe}" />
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="防走神检测" Style="{StaticResource SettingLabel}" />
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding PresenceDetectionEnabled}" />
                            </Grid>
                            <Grid Margin="0,0,0,12" Visibility="{Binding PresenceDetectionEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="离开检测时长（秒）" Style="{StaticResource SettingLabel}" />
                                <ui:NumberBox Grid.Column="1" Value="{Binding PresenceDetectionSeconds, UpdateSourceTrigger=PropertyChanged}" MinWidth="70" Minimum="3" Maximum="30" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="摄像头选择" Style="{StaticResource SettingLabel}" />
                                <ComboBox Grid.Column="1" Width="180"
                                          ItemsSource="{Binding AvailableCameras}"
                                          SelectedIndex="{Binding SelectedCameraIndex}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="提醒" Style="{StaticResource SectionTitle}" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="声音提醒" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="专注/休息结束时播放提示音" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding SoundEnabled}" VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="弹窗提醒" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="屏幕顶部显示灵动岛通知" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding PopupEnabled}" VerticalAlignment="Center" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="系统通知" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="使用 Windows 通知中心提醒" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding SystemNotificationEnabled}" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="外观" Style="{StaticResource SectionTitle}" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="主题" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="选择浅色、深色或跟随系统" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="180"
                                      SelectedValue="{Binding Theme}" SelectedValuePath="Tag" VerticalAlignment="Center">
                                <ComboBoxItem Content="跟随系统" Tag="system" />
                                <ComboBoxItem Content="浅色" Tag="light" />
                                <ComboBoxItem Content="深色" Tag="dark" />
                            </ComboBox>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="动画效果" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="呼吸、缩放等过渡动画" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding AnimationEnabled}" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="系统" Style="{StaticResource SectionTitle}" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="托盘运行" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="最小化后在系统托盘继续运行" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding TrayEnabled}" VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="关闭时最小化到托盘" Style="{StaticResource SettingLabel}" />
                                <TextBlock Text="点击关闭按钮时隐藏到托盘而非退出" Style="{StaticResource FinePrint}" Foreground="{DynamicResource SpotifyTextTertiaryBrush}" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CloseToTray}" VerticalAlignment="Center" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="开机自启" Style="{StaticResource SettingLabel}" />
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoStartEnabled}" />
                        </Grid>
                    </StackPanel>
            </Border>

            <Separator Margin="0,4,0,12" />

            <Button Style="{StaticResource SpotifyPillButton}" Click="Save_Click" FontSize="14" Padding="22,10"
                       HorizontalAlignment="Right" Margin="0,12,0,0">
                保存
            </Button>
        </StackPanel>
    </ScrollViewer>
</Page>
