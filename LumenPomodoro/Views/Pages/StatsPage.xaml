<Page x:Class="LumenPomodoro.Views.Pages.StatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:LumenPomodoro.Controls"
      ScrollViewer.CanContentScroll="False">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="StatsSection" TargetType="Border">
                <Setter Property="Margin" Value="0,0,0,16" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{DynamicResource SpotifySurface1Brush}" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
        <StackPanel Margin="24,24,24,96" MaxWidth="640" HorizontalAlignment="Center">

            <!-- 标题区 -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="统计" Style="{StaticResource PageTitle}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" x:Name="PeriodCombo" SelectedIndex="0" MinWidth="60" Margin="16,0,0,0"
                          VerticalAlignment="Center" SelectionChanged="PeriodCombo_SelectionChanged">
                    <ComboBoxItem Content="日" />
                    <ComboBoxItem Content="周" />
                    <ComboBoxItem Content="月" />
                </ComboBox>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SpotifyButton}" Click="PrevDate_Click" FontSize="12" Padding="6,2" Width="28" Height="28">
                        <TextBlock Text="◀" FontSize="12" />
                    </Button>
                    <Button Style="{StaticResource SpotifyButton}" Click="NextDate_Click" FontSize="12" Padding="6,2"
                               IsEnabled="{Binding CanGoNext}" Width="28" Height="28" Margin="4,0,0,0">
                        <TextBlock Text="▶" FontSize="12" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 概览卡片 -->
            <Border Style="{StaticResource StatsSection}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding CompletedPomodoros, StringFormat='{}{0}'}"
                                   FontSize="36" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SpotifyGreenBrush}" />
                        <TextBlock Text="完成番茄" Foreground="{DynamicResource SpotifyTextSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding TotalFocusMinutes, StringFormat='{}{0}'}"
                                   FontSize="36" FontWeight="SemiBold"
                                   Foreground="{StaticResource SuccessBrush}" />
                        <TextBlock Text="专注分钟" Foreground="{DynamicResource SpotifyTextSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding AvgQualityScore, StringFormat='{}{0:F1}'}"
                                   FontSize="36" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SpotifyTextPrimaryBrush}" />
                        <TextBlock Text="平均质量" Foreground="{DynamicResource SpotifyTextSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="{Binding StreakDays, StringFormat='{}{0}'}"
                                   FontSize="36" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SpotifyTextPrimaryBrush}" />
                        <TextBlock Text="连续天数" Foreground="{DynamicResource SpotifyTextSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 目标进度 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="目标进度" Style="{StaticResource SectionTitle}" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding GoalProgress}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,12">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource Caption}" />
                                        <TextBlock HorizontalAlignment="Right" Style="{StaticResource Caption}">
                                            <Run Text="{Binding CurrentMinutes, Mode=OneWay}" /><Run Text=" / " /><Run Text="{Binding TargetMinutes, Mode=OneWay}" /><Run Text=" 分钟" />
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar Minimum="0" Maximum="100"
                                                 Value="{Binding ProgressPercent}"
                                                 Height="8"
                                                 Foreground="{DynamicResource SpotifyGreenBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 科目均衡 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="科目均衡" Style="{StaticResource SectionTitle}" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding CategoryBreakdown}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Category}" FontSize="13" VerticalAlignment="Center" />
                                    <Grid Grid.Column="1" Margin="8,0">
                                        <ProgressBar Minimum="0" Maximum="{Binding DataContext.MaxCategoryMinutes, RelativeSource={RelativeSource AncestorType=Page}}"
                                                     Value="{Binding TotalMinutes}" Height="8"
                                                     Foreground="{DynamicResource SpotifyGreenBrush}" />
                                    </Grid>
                                    <TextBlock Grid.Column="2" Text="{Binding TotalMinutes, StringFormat='{}{0} 分'}" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding ZeroCategoryWarning}" Foreground="#EF4444" FontSize="12" Margin="0,8,0,0"
                               Visibility="{Binding HasZeroCategory, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Border>

            <!-- 年度热力图 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="年度热力图" Style="{StaticResource SectionTitle}" />
                    <controls:HeatmapCalendar HeatmapDays="{Binding HeatmapDays}" />
                </StackPanel>
            </Border>

            <!-- 时段分布 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="时段分布" Style="{StaticResource SectionTitle}" />
                    <controls:HourlyDistributionChart HourlyData="{Binding HourlyData}" />
                </StackPanel>
            </Border>

            <!-- 任务分布 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="任务分布" Style="{StaticResource SectionTitle}" />
                    <controls:TaskDonutChart TaskSlices="{Binding TaskBreakdown}" />
                </StackPanel>
            </Border>

            <!-- 周趋势 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="周趋势" Style="{StaticResource SectionTitle}" />
                    <controls:WeeklyTrendChart WeeklyData="{Binding WeeklyTrend}" />
                </StackPanel>
            </Border>

            <!-- 效率趋势 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="效率趋势" Style="{StaticResource SectionTitle}" />
                    <controls:EfficiencyTrendChart EfficiencyData="{Binding EfficiencyTrend}" />
                </StackPanel>
            </Border>

            <!-- 对比自己 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="对比自己" Style="{StaticResource SectionTitle}" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Comparisons}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource Caption}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Run Text="{Binding CurrentValue, Mode=OneWay}" /><Run Text=" 分钟" />
                                    </TextBlock>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPositive}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource SpotifyErrorRedBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:+0.0;-0.0;0}%">
                                                <Binding Path="ChangePercent" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 智能洞察 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="智能洞察" Style="{StaticResource SectionTitle}" />
                    <ItemsControl ItemsSource="{Binding Insights}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="12"
                                        Background="{DynamicResource SpotifySurface2Brush}"
                                        CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource Caption}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource FinePrint}"
                                                   Margin="0,4,0,0" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SpotifyTextSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 数据导出 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="数据导出" Style="{StaticResource SectionTitle}" />
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource SpotifyButton}" Click="ExportCsv_Click" Padding="12,8" Margin="0,0,8,0">
                            导出 CSV
                        </Button>
                        <Button Style="{StaticResource SpotifyButton}" Click="ExportJson_Click" Padding="12,8">
                            导出 JSON
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
