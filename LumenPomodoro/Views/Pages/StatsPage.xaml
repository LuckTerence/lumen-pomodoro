<Page x:Class="LumenPomodoro.Views.Pages.StatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:LumenPomodoro.Controls"
      xmlns:converters="clr-namespace:LumenPomodoro.Converters"
      ScrollViewer.CanContentScroll="False"
      Background="Transparent">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:NonEmptyToVisibleConverter x:Key="NonEmptyToVisibleConverter" />

            <!-- 极光渐变 -->
            <LinearGradientBrush x:Key="AuroraGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2563EB" Offset="0" />
                <GradientStop Color="#34D399" Offset="1" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
        <StackPanel Margin="24,16,24,96" MaxWidth="432" HorizontalAlignment="Center">

            <!-- ===== 标题区 ===== -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="统计" FontSize="21" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="#3327272A" CornerRadius="16" Padding="12,6" Margin="16,0,0,0"
                        VerticalAlignment="Center">
                    <ComboBox x:Name="PeriodCombo" SelectedIndex="0" MinWidth="50"
                              Background="Transparent" BorderThickness="0"
                              Foreground="#B3FFFFFF" FontSize="13"
                              SelectionChanged="PeriodCombo_SelectionChanged">
                        <ComboBoxItem Content="日" Foreground="#B3FFFFFF" Background="#3327272A" />
                        <ComboBoxItem Content="周" Foreground="#B3FFFFFF" Background="#3327272A" />
                        <ComboBoxItem Content="月" Foreground="#B3FFFFFF" Background="#3327272A" />
                    </ComboBox>
                </Border>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Click="PrevDate_Click" Width="28" Height="28" Cursor="Hand"
                            Background="Transparent" BorderThickness="0">
                        <TextBlock Text="◀" FontSize="10" Foreground="#6B7280" />
                    </Button>
                    <Button Click="NextDate_Click" Width="28" Height="28" Cursor="Hand"
                            Background="Transparent" BorderThickness="0"
                            IsEnabled="{Binding CanGoNext}">
                        <TextBlock Text="▶" FontSize="10" Foreground="#6B7280" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== 过滤栏 ===== -->
            <!-- 过滤切换按钮 -->
            <Button Content="🔍 过滤" Click="ToggleFilter_Click"
                    Foreground="#6B7280" Background="Transparent" BorderThickness="0"
                    FontSize="12" HorizontalAlignment="Right" Margin="0,0,0,8"
                    Cursor="Hand" />

            <Border Background="#3327272A" CornerRadius="16" Padding="16" Margin="0,0,0,16"
                    Visibility="{Binding IsFilterVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <DatePicker SelectedDate="{Binding FilterDateFrom}" FontSize="12"
                                Margin="0,0,0,8" />
                    <DatePicker SelectedDate="{Binding FilterDateTo}" FontSize="12"
                                Margin="0,0,0,8" />
                    <TextBox Text="{Binding FilterKeyword, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12"
                             Background="#1AFFFFFF" Foreground="White" BorderThickness="0"
                             Padding="8,6" Margin="0,0,0,8" />
                    <ComboBox ItemsSource="{Binding AvailableTasks}"
                              SelectedItem="{Binding SelectedFilterTask}"
                              DisplayMemberPath="Name"
                              FontSize="12" Margin="0,0,0,8"
                              Background="#1AFFFFFF" Foreground="White" BorderThickness="0" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="重置" Click="ResetFilter_Click"
                                Foreground="#6B7280" Background="Transparent" BorderThickness="0"
                                FontSize="12" Cursor="Hand" Padding="8,4" />
                        <Button Content="应用" Click="ApplyFilter_Click"
                                Foreground="White" Background="#3B82F6" BorderThickness="0"
                                FontSize="12" Cursor="Hand" Padding="16,4" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== 空状态 ===== -->
            <StackPanel x:Name="EmptyStatsArea" Margin="0,40,0,0" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="0" FontSize="48" Foreground="{StaticResource AccentBaseBrush}"
                           HorizontalAlignment="Center" Opacity="0.6" Margin="0,0,0,16" />
                <TextBlock Text="暂无统计数据" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="完成第一个番茄后，这里会显示你的专注数据" FontSize="12"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0" />
            </StackPanel>

            <!-- ===== 概览卡片 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding CompletedPomodoros, StringFormat='{}{0}'}"
                                   FontSize="28" FontWeight="SemiBold" Foreground="#34D399"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="番茄钟" FontSize="11" Foreground="#6B7280"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalFocusMinutes, StringFormat='{}{0}'}"
                                   FontSize="28" FontWeight="SemiBold" Foreground="White"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="分钟" FontSize="11" Foreground="#6B7280"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding AvgQualityScore, StringFormat='{}{0:F1}'}"
                                   FontSize="28" FontWeight="SemiBold" Foreground="White"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="质量" FontSize="11" Foreground="#6B7280"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding StreakDays, StringFormat='{}{0}'}"
                                   FontSize="28" FontWeight="SemiBold" Foreground="White"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="连续" FontSize="11" Foreground="#6B7280"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== 成就徽章 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding HasAchievements, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="成就" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Achievements}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,6" Padding="10,8" CornerRadius="8"
                                        Background="#1A34D399">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="13" Foreground="White" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Subtitle}" FontSize="10" Foreground="#6B7280" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ===== 目标进度 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="目标进度" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding GoalProgress}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,12">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="{Binding Label}" FontSize="12" Foreground="#6B7280" />
                                        <TextBlock HorizontalAlignment="Right" FontSize="12" Foreground="#6B7280">
                                            <Run Text="{Binding CurrentMinutes, Mode=OneWay}" />
                                            <Run Text=" / " />
                                            <Run Text="{Binding TargetMinutes, Mode=OneWay}" />
                                            <Run Text=" 分钟" />
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercent}"
                                                 Height="4" Foreground="#34D399" Background="#27272A" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ===== 科目均衡 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="科目均衡" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding CategoryBreakdown}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Category}" FontSize="13" Foreground="#B3FFFFFF" VerticalAlignment="Center" />
                                    <Grid Grid.Column="1" Margin="8,0">
                                        <ProgressBar Minimum="0"
                                                     Maximum="{Binding DataContext.MaxCategoryMinutes, RelativeSource={RelativeSource AncestorType=Page}}"
                                                     Value="{Binding TotalMinutes}" Height="4"
                                                     Foreground="#34D399" Background="#27272A" />
                                    </Grid>
                                    <TextBlock Grid.Column="2" FontSize="12" Foreground="#6B7280"
                                               HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Run Text="{Binding TotalMinutes, Mode=OneWay}" />
                                        <Run Text=" 分" />
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding ZeroCategoryWarning}" Foreground="#EF4444" FontSize="12" Margin="0,8,0,0"
                               Visibility="{Binding HasZeroCategory, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Click="AddMissingCategory_Click" Padding="12,6" Margin="0,4,0,0" Cursor="Hand"
                            HorizontalAlignment="Left"
                            Visibility="{Binding HasZeroCategory, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#1A3B82F6" BorderBrush="#333B82F6" BorderThickness="1"
                                        CornerRadius="14" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="+ 添加缺失科目的任务" FontSize="11" Foreground="#60A5FA" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- ===== 年度热力图 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="年度热力图" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" />
                    <controls:HeatmapCalendar HeatmapDays="{Binding HeatmapDays}" />
                </StackPanel>
            </Border>

            <!-- ===== 时段分布 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="时段分布" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" />
                    <controls:HourlyDistributionChart HourlyData="{Binding HourlyData}" />
                </StackPanel>
            </Border>

            <!-- ===== 任务分布 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="任务分布" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" />
                    <controls:TaskDonutChart TaskSlices="{Binding TaskBreakdown}" />
                </StackPanel>
            </Border>

            <!-- ===== 周趋势 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="周趋势" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" />
                    <controls:WeeklyTrendChart WeeklyData="{Binding WeeklyTrend}" />
                </StackPanel>
            </Border>

            <!-- ===== 对比自己 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="对比自己" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Comparisons}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Run Text="{Binding CurrentValue, Mode=OneWay}" />
                                        <Run Text=" 分钟" />
                                    </TextBlock>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#34D399" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPositive}" Value="False">
                                                        <Setter Property="Foreground" Value="#EF4444" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:+0.0;-0.0;0}%">
                                                <Binding Path="ChangePercent" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ===== 智能洞察 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="智能洞察" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" />
                    <ItemsControl ItemsSource="{Binding Insights}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,8,0,0" Padding="12" Background="#1A27272A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" Foreground="#B3FFFFFF" />
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#6B7280"
                                                   Margin="0,4,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ActionHint}" FontSize="11" Foreground="#34D399"
                                                   Margin="0,4,0,0" FontStyle="Italic" TextWrapping="Wrap"
                                                   Visibility="{Binding ActionHint, Converter={StaticResource NonEmptyToVisibleConverter}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ===== 数据导出 ===== -->
            <Border Background="#3327272A" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="数据导出" FontSize="14" FontWeight="SemiBold" Foreground="#B3FFFFFF" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button Click="ExportCsv_Click" Padding="16,8" Cursor="Hand"
                                Background="#1A27272A" BorderBrush="#26FFFFFF" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="16" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="导出 CSV" FontSize="12" Foreground="#B3FFFFFF" />
                        </Button>
                        <Button Click="ExportJson_Click" Padding="16,8" Margin="8,0,0,0" Cursor="Hand"
                                Background="#1A27272A" BorderBrush="#26FFFFFF" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="16" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="导出 JSON" FontSize="12" Foreground="#B3FFFFFF" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
