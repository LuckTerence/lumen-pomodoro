<Page x:Class="LumenPomodoro.Views.Pages.StatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatsDateLabel}" Style="{StaticResource PageTitle}" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="日" Style="{StaticResource FinePrint}" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ui:ToggleSwitch IsChecked="{Binding IsDayPeriod}" />
                <TextBlock Text="周" Style="{StaticResource FinePrint}" VerticalAlignment="Center" Margin="4,0,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <ui:Button Appearance="Transparent" Click="PrevDate_Click" FontSize="12" Padding="6,2">
                    <ui:SymbolIcon Symbol="ChevronLeft24" />
                </ui:Button>
                <ui:Button Appearance="Transparent" Click="NextDate_Click" FontSize="12" Padding="6,2" IsEnabled="{Binding CanGoNext}">
                    <ui:SymbolIcon Symbol="ChevronRight24" />
                </ui:Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <ui:CardControl Margin="0,0,12,0" Padding="28,20">
                        <ui:CardControl.Content>
                            <StackPanel HorizontalAlignment="Center" Width="140">
                                <TextBlock Text="{Binding CompletedPomodoros}" Style="{StaticResource StatNumber}"
                                           Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                                <TextBlock Text="完成番茄钟" Style="{StaticResource Caption}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                            </StackPanel>
                        </ui:CardControl.Content>
                    </ui:CardControl>

                    <ui:CardControl Padding="28,20">
                        <ui:CardControl.Content>
                            <StackPanel HorizontalAlignment="Center" Width="140">
                                <TextBlock Text="{Binding TotalFocusMinutes}" Style="{StaticResource StatNumber}"
                                           Foreground="{StaticResource SuccessBrush}" />
                                <TextBlock Text="专注时长(分)" Style="{StaticResource Caption}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                            </StackPanel>
                        </ui:CardControl.Content>
                    </ui:CardControl>
                </StackPanel>

                <TextBlock Text="{Binding StatsDateLabel}" Style="{StaticResource FinePrint}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
