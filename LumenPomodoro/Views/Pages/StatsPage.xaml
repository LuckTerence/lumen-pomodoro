<Page x:Class="LumenPomodoro.Views.Pages.StatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:LumenPomodoro.Controls"
      ScrollViewer.CanContentScroll="False">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="StatsSection" TargetType="Border">
                <Setter Property="Margin" Value="0,0,0,16" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
        <StackPanel Margin="24,24,24,96" MaxWidth="640" HorizontalAlignment="Center">

            <!-- 标题区 -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="统计" Style="{StaticResource PageTitle}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" x:Name="PeriodCombo" SelectedIndex="0" MinWidth="60" Margin="16,0,0,0"
                          VerticalAlignment="Center" SelectionChanged="PeriodCombo_SelectionChanged">
                    <ComboBoxItem Content="日" />
                    <ComboBoxItem Content="周" />
                    <ComboBoxItem Content="月" />
                </ComboBox>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Appearance="Transparent" Click="PrevDate_Click" FontSize="12" Padding="6,2">
                        <ui:SymbolIcon Symbol="ChevronLeft24" />
                    </ui:Button>
                    <ui:Button Appearance="Transparent" Click="NextDate_Click" FontSize="12" Padding="6,2"
                               IsEnabled="{Binding CanGoNext}">
                        <ui:SymbolIcon Symbol="ChevronRight24" />
                    </ui:Button>
                </StackPanel>
            </Grid>

            <!-- 概览卡片 -->
            <Border Style="{StaticResource StatsSection}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding CompletedPomodoros, StringFormat='{}{0}'}"
                                   FontSize="36" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="完成番茄" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding TotalFocusMinutes, StringFormat='{}{0}'}"
                                   FontSize="36" FontWeight="SemiBold"
                                   Foreground="{StaticResource SuccessBrush}" />
                        <TextBlock Text="专注分钟" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 年度热力图 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="年度热力图" Style="{StaticResource SectionTitle}" />
                    <controls:HeatmapCalendar HeatmapDays="{Binding HeatmapDays}" />
                </StackPanel>
            </Border>

            <!-- 时段分布 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="时段分布" Style="{StaticResource SectionTitle}" />
                    <controls:HourlyDistributionChart HourlyData="{Binding HourlyData}" />
                </StackPanel>
            </Border>

            <!-- 任务分布 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="任务分布" Style="{StaticResource SectionTitle}" />
                    <controls:TaskDonutChart TaskSlices="{Binding TaskBreakdown}" />
                </StackPanel>
            </Border>

            <!-- 周趋势 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="周趋势" Style="{StaticResource SectionTitle}" />
                    <controls:WeeklyTrendChart WeeklyData="{Binding WeeklyTrend}" />
                </StackPanel>
            </Border>

            <!-- 智能洞察 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="智能洞察" Style="{StaticResource SectionTitle}" />
                    <ItemsControl ItemsSource="{Binding Insights}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="12"
                                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                        CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource Caption}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource FinePrint}"
                                                   Margin="0,4,0,0" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 数据导出 -->
            <Border Style="{StaticResource StatsSection}">
                <StackPanel>
                    <TextBlock Text="数据导出" Style="{StaticResource SectionTitle}" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Appearance="Secondary" Click="ExportCsv_Click" Padding="12,8" Margin="0,0,8,0">
                            导出 CSV
                        </ui:Button>
                        <ui:Button Appearance="Secondary" Click="ExportJson_Click" Padding="12,8">
                            导出 JSON
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
