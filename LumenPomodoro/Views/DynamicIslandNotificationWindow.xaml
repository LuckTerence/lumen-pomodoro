<Window x:Class="LumenPomodoro.Views.DynamicIslandNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DynamicIslandNotification"
        SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Topmost="True"
        ShowInTaskbar="False" ShowActivated="False"
        Background="Transparent"
        MouseLeftButtonUp="Island_MouseLeftButtonUp">
  <Border x:Name="PillBorder" CornerRadius="24" Background="#F01A1A1A"
          Padding="16,10" Margin="0" Cursor="Hand"
          MinWidth="160" MaxWidth="420"
          RenderTransformOrigin="0.5,0.5">
    <Border.RenderTransform>
      <TransformGroup>
        <ScaleTransform x:Name="PillScale" ScaleX="1" ScaleY="1" />
        <TranslateTransform x:Name="PillTranslate" Y="0" />
      </TransformGroup>
    </Border.RenderTransform>
    <Border.Effect>
      <DropShadowEffect x:Name="PillShadow" ShadowDepth="0" BlurRadius="20" Opacity="0.45" Color="Black"/>
    </Border.Effect>
    <StackPanel x:Name="RootStack">
      <!-- Compact / Transient 主行 -->
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
        <Ellipse x:Name="TaskDot" Width="8" Height="8" Margin="0,0,8,0"
                 Fill="#3B82F6" Visibility="Collapsed" VerticalAlignment="Center"/>
        <TextBlock x:Name="TitleBlock" FontSize="13" FontWeight="SemiBold"
                   Foreground="White" VerticalAlignment="Center" MaxWidth="120"
                   TextTrimming="CharacterEllipsis"/>
        <TextBlock x:Name="CountdownBlock" FontSize="22" FontWeight="Light"
                   Foreground="White" VerticalAlignment="Center"
                   Margin="10,0,0,0" FontFamily="Inter Light"
                   Visibility="Collapsed"/>
        <TextBlock x:Name="MessageBlock" FontSize="12" Foreground="#CCFFFFFF"
                   Margin="10,0,0,0" VerticalAlignment="Center" MaxWidth="240"
                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
      </StackPanel>

      <!-- 任务条：Expanded 且 idle 时可选；专注中只读当前任务 -->
      <ScrollViewer x:Name="TasksScroller" HorizontalScrollBarVisibility="Hidden"
                    VerticalScrollBarVisibility="Disabled" Margin="0,10,0,0"
                    Visibility="Collapsed" MaxWidth="380">
        <StackPanel x:Name="TasksPanel" Orientation="Horizontal"/>
      </ScrollViewer>

      <!-- Expanded 操作区 -->
      <StackPanel x:Name="ActionsPanel" Orientation="Horizontal"
                  HorizontalAlignment="Center" Margin="0,10,0,0"
                  Visibility="Collapsed">
        <Button x:Name="PauseResumeButton" Content="暂停" Click="PauseResume_Click"
                Margin="0,0,6,0" Padding="12,5" Cursor="Hand"
                Background="#33FFFFFF" Foreground="White" BorderThickness="0"
                FontSize="12"/>
        <Button x:Name="SkipBreakButton" Content="结束休息" Click="SkipBreak_Click"
                Margin="0,0,6,0" Padding="12,5" Cursor="Hand"
                Background="#33FFFFFF" Foreground="White" BorderThickness="0"
                FontSize="12" Visibility="Collapsed"/>
        <Button x:Name="StartFocusButton" Content="开始" Click="StartFocus_Click"
                Margin="0,0,6,0" Padding="14,5" Cursor="Hand"
                Background="#3B82F6" Foreground="White" BorderThickness="0"
                FontSize="12" FontWeight="SemiBold" Visibility="Collapsed"/>
        <Button x:Name="OpenMainButton" Content="主窗口" Click="OpenMain_Click"
                Padding="10,5" Cursor="Hand" FontSize="12"
                Background="Transparent" Foreground="#AAB0B8" BorderThickness="0"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
