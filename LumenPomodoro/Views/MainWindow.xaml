<Window x:Class="LumenPomodoro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:LumenPomodoro.ViewModels"
        xmlns:converters="clr-namespace:LumenPomodoro.Converters"
        mc:Ignorable="d"
        Title="Lumen Pomodoro" Height="520" Width="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StatusConverter x:Key="StatusConverter" />
        <converters:StatusToVisibilityConverter x:Key="StatusToVisibilityConverter" />

        <Storyboard x:Key="FadeInUpStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" EasingFunction="{StaticResource QuadraticEase}" />
            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4" EasingFunction="{StaticResource QuadraticEase}" />
        </Storyboard>

        <QuadraticEase x:Key="QuadraticEase" EasingMode="EaseOut" />

        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource GlassBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Color="{DynamicResource PrimaryTextColor}" Opacity="0.15" />
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="10" Color="{DynamicResource PrimaryColor}" Opacity="0.5" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="CircleButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="TaskComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>
    
    <Grid>
        <Border x:Name="MainBorder" Style="{StaticResource GlassPanel}" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform Y="0" />
            </Border.RenderTransform>
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Style="{StaticResource CircleButton}" Width="32" Height="32" Padding="0" Click="MinimizeButton_Click">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                    <Button Style="{StaticResource CircleButton}" Width="32" Height="32" Padding="0" Click="CloseButton_Click">
                        <TextBlock Text="&#xE92B;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                </StackPanel>
                
                <StackPanel Grid.Row="1" Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <ComboBox x:Name="TaskComboBox" Style="{StaticResource TaskComboBox}" Width="200"
                              ItemsSource="{Binding Tasks}"
                              SelectedItem="{Binding SelectedTask}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Rectangle Width="8" Height="8" Fill="{Binding Color}" RadiusX="4" RadiusY="4" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding Name}" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button x:Name="ManageTasksButton" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="8" Click="ManageTasksButton_Click">
                        <TextBlock Text="&#xE87A;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                </StackPanel>
                
                <Grid Grid.Row="2" Margin="0,32,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="{Binding CurrentStatus, Converter={StaticResource StatusConverter}}" 
                               FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}" TextAlignment="Center" Margin="0,0,0,8" />
                    
                    <TextBlock Grid.Row="1" Text="{Binding RemainingTime}" 
                               FontSize="72" FontWeight="Light" Foreground="{DynamicResource PrimaryTextBrush}" 
                               TextAlignment="Center" FontFamily="Segoe UI Light">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="5" Color="{DynamicResource PrimaryTextColor}" Opacity="0.1" />
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>
                
                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <Border  ClipToBounds="True">
                        <ProgressBar x:Name="ProgressBar" 
                                     Value="{Binding Progress}" 
                                     Minimum="0" 
                                     Maximum="100" 
                                     Height="6" 
                                     Background="{DynamicResource BorderBrush}" 
                                     BorderThickness="0">
                        <ProgressBar.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{DynamicResource PrimaryColor}" Offset="0" />
                                <GradientStop Color="{DynamicResource SuccessColor}" Offset="1" />
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                        </ProgressBar>
                    </Border>
                </Grid>
                
                <Grid Grid.Row="4" Margin="0,24,0,0">
                    <StackPanel x:Name="CameraStatusPanel" Visibility="{Binding IsCameraAlertActive, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="0,0,8,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                             From="1" To="0.3" Duration="0.8s" 
                                                             AutoReverse="True" RepeatBehavior="Forever" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="{Binding CameraStatus}" FontSize="12" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,8,0" />
                        <Button x:Name="StopCameraButton" Style="{StaticResource SecondaryButton}" 
                                Padding="8,4" FontSize="12" Click="StopCameraButton_Click">
                            关闭提醒
                        </Button>
                    </StackPanel>
                </Grid>
                
                <Grid Grid.Row="5" Margin="0,24,0,0">
                    <StackPanel x:Name="IdlePanel" Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Idle}"
                                Orientation="Vertical" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="StartFocusButton" Style="{StaticResource PrimaryButton}" Click="StartFocusButton_Click">
                                开始专注
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0"
                                    Visibility="{Binding IsPendingBreak, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button x:Name="PendingShortBreakButton" Style="{StaticResource PrimaryButton}" Click="StartShortBreakButton_Click" Background="#10B981">
                                开始短休息
                            </Button>
                            <Button x:Name="PendingLongBreakButton" Style="{StaticResource SecondaryButton}" Click="StartLongBreakButton_Click" Margin="8,0,0,0">
                                长休息
                            </Button>
                            <Button x:Name="PendingSkipBreakButton" Style="{StaticResource SecondaryButton}" Click="SkipBreakButton_Click" Margin="8,0,0,0">
                                跳过
                            </Button>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel x:Name="FocusPanel" Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Focus}"
                                Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="PauseButton" Style="{StaticResource SecondaryButton}" Click="PauseButton_Click">
                            暂停
                        </Button>
                        <Button x:Name="ResetButton" Style="{StaticResource SecondaryButton}" Click="ResetButton_Click">
                            重置
                        </Button>
                    </StackPanel>
                    
                    <StackPanel x:Name="PausedPanel" Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Paused}"
                                Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="ResumeButton" Style="{StaticResource PrimaryButton}" Click="ResumeButton_Click">
                            继续
                        </Button>
                        <Button x:Name="ResetButton2" Style="{StaticResource SecondaryButton}" Click="ResetButton_Click">
                            重置
                        </Button>
                    </StackPanel>
                    
                    <StackPanel x:Name="CompletedPanel" Visibility="{Binding IsFocusCompleted, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="StartShortBreakButton" Style="{StaticResource PrimaryButton}" Click="StartShortBreakButton_Click">
                            开始短休息
                        </Button>
                        <Button x:Name="StartLongBreakButton" Style="{StaticResource SecondaryButton}" Click="StartLongBreakButton_Click">
                            长休息
                        </Button>
                        <Button x:Name="SkipBreakButton" Style="{StaticResource SecondaryButton}" Click="SkipBreakButton_Click">
                            跳过休息
                        </Button>
                    </StackPanel>
                    
                    <StackPanel x:Name="BreakPanel" Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Break}"
                                Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="EndBreakButton" Style="{StaticResource PrimaryButton}" Click="EndBreakButton_Click">
                            结束休息
                        </Button>
                    </StackPanel>
                </Grid>
                
                <Grid Grid.Row="6" Margin="0,24,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Cursor="Hand" MouseDown="StatsPanel_MouseDown">
                            <TextBlock Text="{Binding TodayStats.CompletedPomodoros}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" />
                            <TextBlock Text="今日完成" FontSize="12" Foreground="{DynamicResource TertiaryTextBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="16,0,0,0" Cursor="Hand" MouseDown="StatsPanel_MouseDown">
                            <TextBlock Text="{Binding TodayStats.TotalFocusMinutes}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" />
                            <TextBlock Text="专注时长(分)" FontSize="12" Foreground="{DynamicResource TertiaryTextBrush}" />
                        </StackPanel>
                        <Button x:Name="SettingsButton" Style="{StaticResource CircleButton}" Width="40" Height="40" Click="SettingsButton_Click">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

