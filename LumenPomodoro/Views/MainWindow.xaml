<Window x:Class="LumenPomodoro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:pages="clr-namespace:LumenPomodoro.Views.Pages"
        Title="Lumen Pomodoro" Width="480" Height="680" MinHeight="560"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterScreen"
        WindowStyle="None" Background="Transparent"
        Icon="pack://application:,,,/app.ico">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="GlassBorder" CornerRadius="12"
            Background="#A6181818" BorderBrush="{StaticResource DividerBrush}"
            BorderThickness="1" MouseLeftButtonDown="WindowDragArea_MouseLeftButtonDown"
            RenderTransformOrigin="0.5,0.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- 标题栏 -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Lumen" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentBaseBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Pomodoro" FontSize="14" FontWeight="Light" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="MinimizeBtn" Width="46" Height="32" Background="Transparent" BorderThickness="0" Click="MinimizeButton_Click" Cursor="Hand">
                        <Rectangle Width="12" Height="1" Fill="{StaticResource TextTertiaryBrush}"/>
                    </Button>
                    <Button x:Name="MaximizeBtn" Width="46" Height="32" Background="Transparent" BorderThickness="0" Click="MaximizeButton_Click" Cursor="Hand">
                        <Border Width="10" Height="10" BorderBrush="{StaticResource TextTertiaryBrush}" BorderThickness="1.5" CornerRadius="2"/>
                    </Button>
                    <Button x:Name="CloseBtn" Width="46" Height="32" Background="Transparent" BorderThickness="0" Click="CloseButton_Click" Cursor="Hand">
                        <Grid>
                            <Line X1="0" Y1="0" X2="10" Y2="10" Stroke="{StaticResource TextTertiaryBrush}" StrokeThickness="1.5"/>
                            <Line X1="10" Y1="0" X2="0" Y2="10" Stroke="{StaticResource TextTertiaryBrush}" StrokeThickness="1.5"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
            <!-- 内容 -->
            <Border Grid.Row="1">
                <ui:NavigationView x:Name="NavView" PaneDisplayMode="Top" IsBackButtonVisible="Collapsed" Background="Transparent">
                    <ui:NavigationView.MenuItems>
                        <ui:NavigationViewItem Content="计时器" Icon="{ui:SymbolIcon Timer24}" TargetPageType="{x:Type pages:TimerPage}"/>
                        <ui:NavigationViewItem Content="任务" Icon="{ui:SymbolIcon TaskListSquareLtr24}" TargetPageType="{x:Type pages:TasksPage}"/>
                        <ui:NavigationViewItem Content="统计" Icon="{ui:SymbolIcon ChartMultiple24}" TargetPageType="{x:Type pages:StatsPage}"/>
                        <ui:NavigationViewItem Content="设置" Icon="{ui:SymbolIcon Settings24}" TargetPageType="{x:Type pages:SettingsPage}"/>
                    </ui:NavigationView.MenuItems>
                </ui:NavigationView>
            </Border>
            <Border Grid.Row="2" Height="1" Background="{StaticResource DividerBrush}"/>
        </Grid>
    </Border>
</Window>
