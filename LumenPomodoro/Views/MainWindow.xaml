<ui:FluentWindow x:Class="LumenPomodoro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:pages="clr-namespace:LumenPomodoro.Views.Pages"
        mc:Ignorable="d"
        Title="Lumen Pomodoro" Width="520" Height="640" MinHeight="520"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="AppTitleBar"
                     Title="Lumen Pomodoro"
                     Grid.Row="0"
                     ShowMaximize="False" />

        <ui:NavigationView x:Name="NavView" Grid.Row="1" PaneDisplayMode="Bottom">
            <ui:NavigationView.TitleBar>
                <ui:TitleBar Title="Lumen Pomodoro" ShowMaximize="False" />
            </ui:NavigationView.TitleBar>
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="计时器" Icon="{ui:SymbolIcon Timer24}" TargetPageType="{x:Type pages:TimerPage}" />
                <ui:NavigationViewItem Content="任务" Icon="{ui:SymbolIcon TaskListSquareLtr24}" TargetPageType="{x:Type pages:TasksPage}" />
                <ui:NavigationViewItem Content="统计" Icon="{ui:SymbolIcon ChartMultiple24}" TargetPageType="{x:Type pages:StatsPage}" />
                <ui:NavigationViewItem Content="设置" Icon="{ui:SymbolIcon Settings24}" TargetPageType="{x:Type pages:SettingsPage}" />
            </ui:NavigationView.MenuItems>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
