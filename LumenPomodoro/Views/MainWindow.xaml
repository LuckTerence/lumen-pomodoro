<Window x:Class="LumenPomodoro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:LumenPomodoro.ViewModels"
        xmlns:models="clr-namespace:LumenPomodoro.Models"
        xmlns:converters="clr-namespace:LumenPomodoro.Converters"
        mc:Ignorable="d"
        Title="Lumen Pomodoro" Height="520" Width="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:StatusToVisibilityConverter x:Key="StatusToVisibilityConverter" />

        <QuadraticEase x:Key="QuadraticEase" EasingMode="EaseOut" />

        <!-- Primary pill: DESIGN.md button-primary = 17/400, pill, padding 22x11, scale(0.95) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="Padding" Value="22,11" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="9999" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.95" Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.95" Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small secondary pill: transparent + blue border -->
        <Style x:Key="SmallSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="9999" Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.95" Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.95" Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Text link: no bg, no border, just text -->
        <Style x:Key="TextLinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.95" Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.95" Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings section styles (unchanged) -->
        <Style x:Key="SettingsSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        </Style>
        <Style x:Key="SettingsToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{DynamicResource BorderBrush}" CornerRadius="12">
                            <Ellipse x:Name="Thumb" Fill="White" Width="20" Height="20" Margin="2" HorizontalAlignment="Left" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup Name="CheckStates">
                                    <VisualState Name="Checked">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(Fill).(SolidColorBrush.Color)" To="{DynamicResource PrimaryColor}" />
                                            <ThicknessAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="Margin" To="22,2,2,2" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState Name="Unchecked">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(Fill).(SolidColorBrush.Color)" To="White" />
                                            <ThicknessAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="Margin" To="2,2,2,2" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsInput" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="70" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="9999" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <!-- Full window surface: subtle rounded corners, no border line -->
        <Border x:Name="RootSurface" Background="{DynamicResource GlassBackgroundBrush}" CornerRadius="12">

            <Grid x:Name="ContentRoot">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ===== WINDOW CONTROLS ===== -->
                <Grid Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,6,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Width="24" Height="24" Padding="0" Click="MinimizeButton_Click"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Path Data="M5,12 L19,12" Stroke="{DynamicResource TertiaryTextBrush}" StrokeThickness="1"
                                  Width="24" Height="24" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Button>
                        <Button Width="24" Height="24" Padding="0" Click="CloseButton_Click"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Path Data="M7,7 L17,17 M17,7 L7,17" Stroke="{DynamicResource TertiaryTextBrush}" StrokeThickness="1"
                                  Width="24" Height="24" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ===== TIMER VIEW ===== -->
                <Grid x:Name="TimerView" Grid.Row="1">
                    <Grid VerticalAlignment="Center" Margin="32,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Task name (Idle only, minimal) -->
                        <TextBlock Grid.Row="0" x:Name="TaskNameDisplay"
                                   HorizontalAlignment="Center" Margin="0,0,0,48"
                                   FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}"
                                   Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Idle}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Cursor" Value="Hand" />
                                    <EventSetter Event="MouseDown" Handler="ManageTasksButton_Click" />
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding SelectedTask.Name, Mode=OneWay, FallbackValue='选择任务'}" />
                            <Run Text="  ▾" FontSize="10" Foreground="{DynamicResource TertiaryTextBrush}" />
                        </TextBlock>

                        <!-- HERO: 96px time -->
                        <TextBlock Grid.Row="1" Text="{Binding RemainingTime}"
                                   FontSize="96" FontWeight="Light" Foreground="{DynamicResource PrimaryTextBrush}"
                                   HorizontalAlignment="Center" FontFamily="{DynamicResource InterLight}"
                                   LineHeight="1" Margin="0,0,0,24" />

                        <!-- Progress: 2px, almost invisible -->
                        <Border Grid.Row="2" Margin="48,0,48,48" ClipToBounds="True">
                            <ProgressBar x:Name="ProgressBar" Value="{Binding Progress}" Minimum="0" Maximum="100"
                                         Height="2" Background="{DynamicResource BorderBrush}" BorderThickness="0">
                                <ProgressBar.Foreground>
                                    <SolidColorBrush Color="{DynamicResource PrimaryColor}" />
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </Border>

                        <!-- ===== ACTION BUTTONS ===== -->
                        <Grid Grid.Row="3">
                            <!-- Idle: 开始专注 -->
                            <StackPanel x:Name="IdlePanel"
                                        Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Idle}"
                                        Orientation="Vertical" HorizontalAlignment="Center">
                                <Button x:Name="StartFocusButton" Style="{StaticResource PrimaryButton}" Click="StartFocusButton_Click">
                                    开始专注
                                </Button>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0"
                                            Visibility="{Binding IsPendingBreak, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button x:Name="PendingShortBreakButton" Style="{StaticResource PrimaryButton}" Click="StartShortBreakButton_Click">
                                        短休息
                                    </Button>
                                    <Button x:Name="PendingLongBreakButton" Style="{StaticResource TextLinkButton}" Click="StartLongBreakButton_Click" Margin="8,0,0,0">
                                        长休息
                                    </Button>
                                    <Button x:Name="PendingSkipBreakButton" Style="{StaticResource TextLinkButton}" Click="SkipBreakButton_Click">
                                        跳过
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <!-- Focus: 暂停 · 重置 -->
                            <StackPanel x:Name="FocusPanel"
                                        Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Focus}"
                                        Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="PauseButton" Style="{StaticResource SmallSecondaryButton}" Click="PauseButton_Click">
                                    暂停
                                </Button>
                                <Button x:Name="ResetButton" Style="{StaticResource TextLinkButton}" Click="ResetButton_Click" Margin="8,0,0,0">
                                    重置
                                </Button>
                            </StackPanel>

                            <!-- Paused: 继续 · 重置 -->
                            <StackPanel x:Name="PausedPanel"
                                        Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Paused}"
                                        Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="ResumeButton" Style="{StaticResource PrimaryButton}" Click="ResumeButton_Click">
                                    继续
                                </Button>
                                <Button x:Name="ResetButton2" Style="{StaticResource TextLinkButton}" Click="ResetButton_Click" Margin="8,0,0,0">
                                    重置
                                </Button>
                            </StackPanel>

                            <!-- Break: 结束休息 -->
                            <StackPanel x:Name="BreakPanel"
                                        Visibility="{Binding CurrentStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Break}"
                                        Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="EndBreakButton" Style="{StaticResource PrimaryButton}" Click="EndBreakButton_Click">
                                    结束休息
                                </Button>
                            </StackPanel>

                            <!-- Focus completed -->
                            <StackPanel x:Name="CompletedPanel"
                                        Visibility="{Binding IsFocusCompleted, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="StartShortBreakButton" Style="{StaticResource PrimaryButton}" Click="StartShortBreakButton_Click">
                                    短休息
                                </Button>
                                <Button x:Name="StartLongBreakButton" Style="{StaticResource TextLinkButton}" Click="StartLongBreakButton_Click" Margin="8,0,0,0">
                                    长休息
                                </Button>
                                <Button x:Name="SkipBreakButton" Style="{StaticResource TextLinkButton}" Click="SkipBreakButton_Click">
                                    跳过
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- ===== SETTINGS VIEW ===== -->
                <Grid x:Name="SettingsView" Grid.Row="1" Visibility="Collapsed" Margin="32,8,32,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Button Width="24" Height="24" Padding="0" Click="SettingsButton_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <Path Data="M15,4 L7,12 L15,20" Stroke="{DynamicResource SecondaryTextBrush}" StrokeThickness="1.5"
                                      Width="22" Height="24" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                            </Button>
                            <TextBlock Text="设置" FontSize="21" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel DataContext="{Binding SettingsVM}">
                            <TextBlock Text="计时" Style="{StaticResource SettingsSectionTitle}" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="专注时间（分钟）" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsInput}" Text="{Binding WorkMinutes, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="短休息（分钟）" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsInput}" Text="{Binding ShortBreakMinutes, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="长休息（分钟）" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsInput}" Text="{Binding LongBreakMinutes, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <TextBlock Text="摄像头" Style="{StaticResource SettingsSectionTitle}" Margin="0,16,0,0" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="启用摄像头提醒" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggle}" IsChecked="{Binding CameraAlertEnabled}" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="提醒模式" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" Style="{StaticResource SettingsCombo}" MinWidth="100"
                                          SelectedValue="{Binding CameraAlertMode}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="固定时长" Tag="{x:Static models:CameraAlertMode.FixedDuration}" />
                                    <ComboBoxItem Content="直到确认" Tag="{x:Static models:CameraAlertMode.UntilConfirm}" />
                                    <ComboBoxItem Content="跟随休息" Tag="{x:Static models:CameraAlertMode.FollowBreak}" />
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="固定亮灯时长（秒）" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsInput}" Text="{Binding CameraFixedOnSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="休息期间亮灯" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggle}" IsChecked="{Binding CameraFollowBreakEnabled}" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="摄像头选择" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" Style="{StaticResource SettingsCombo}" MinWidth="120"
                                          ItemsSource="{Binding AvailableCameras}"
                                          SelectedIndex="{Binding SelectedCameraIndex}" />
                            </Grid>
                            <Button Style="{StaticResource TextLinkButton}" Click="TestCameraButton_Click" Padding="10,6" FontSize="12">
                                测试摄像头
                            </Button>

                            <TextBlock Text="提醒" Style="{StaticResource SettingsSectionTitle}" Margin="0,16,0,0" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="声音提醒" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggle}" IsChecked="{Binding SoundEnabled}" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="弹窗提醒" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggle}" IsChecked="{Binding PopupEnabled}" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="系统通知" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggle}" IsChecked="{Binding SystemNotificationEnabled}" />
                            </Grid>

                            <TextBlock Text="外观" Style="{StaticResource SettingsSectionTitle}" Margin="0,16,0,0" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="主题" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" Style="{StaticResource SettingsCombo}" MinWidth="100"
                                          SelectedValue="{Binding Theme}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="跟随系统" Tag="system" />
                                    <ComboBoxItem Content="浅色" Tag="light" />
                                    <ComboBoxItem Content="深色" Tag="dark" />
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="动画效果" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggle}" IsChecked="{Binding AnimationEnabled}" />
                            </Grid>

                            <TextBlock Text="系统" Style="{StaticResource SettingsSectionTitle}" Margin="0,16,0,0" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="托盘运行" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggle}" IsChecked="{Binding TrayEnabled}" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="关闭时最小化到托盘" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggle}" IsChecked="{Binding CloseToTray}" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="开机自启" Style="{StaticResource SettingsLabel}" VerticalAlignment="Center" />
                                <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggle}" IsChecked="{Binding AutoStartEnabled}" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Style="{StaticResource TextLinkButton}" Click="CancelSettings_Click" Margin="0,0,8,0">取消</Button>
                        <Button Style="{StaticResource PrimaryButton}" FontSize="14" Padding="22,10" Click="SaveSettings_Click">保存</Button>
                    </StackPanel>
                </Grid>

                <!-- ===== FOOTER ===== -->
                <Grid Grid.Row="2" Margin="24,0,24,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"
                               VerticalAlignment="Center" Cursor="Hand" MouseDown="StatsPanel_MouseDown">
                        <Run Text="今日 " />
                        <Run Text="{Binding TodayStats.CompletedPomodoros}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" />
                        <Run Text=" · 专注 " />
                        <Run Text="{Binding TodayStats.TotalFocusMinutes}" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold" />
                        <Run Text="分" />
                    </TextBlock>

                    <Button Grid.Column="1" Width="24" Height="24" Padding="0" Click="SettingsButton_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Path Data="M12,15 A3,3 0 1,1 12,9 A3,3 0 1,1 12,15 M19.4,15 A1.65,1.65 0 0,0 18.65,13.28 L18.72,11.55 A1.65,1.65 0 0,0 17.27,10.23 L15.65,9.77 A7.83,7.83 0 0,0 14.23,8.35 L13.77,6.73 A1.65,1.65 0 0,0 12.45,5.28 L10.55,5.28 A1.65,1.65 0 0,0 9.23,6.73 L8.77,8.35 A7.83,7.83 0 0,0 7.35,9.77 L5.73,10.23 A1.65,1.65 0 0,0 4.28,11.55 L4.28,13.45 A1.65,1.65 0 0,0 5.73,14.77 L7.35,15.23 A7.83,7.83 0 0,0 8.77,16.65 L9.23,18.27 A1.65,1.65 0 0,0 10.55,19.72 L12.45,19.72 A1.65,1.65 0 0,0 13.77,18.27 L14.23,16.65 A7.83,7.83 0 0,0 15.65,15.23 L17.27,14.77 A1.65,1.65 0 0,0 19.4,15 Z"
                              Stroke="{DynamicResource TertiaryTextBrush}" StrokeThickness="0.8"
                              Width="20" Height="20" Fill="Transparent" />
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
