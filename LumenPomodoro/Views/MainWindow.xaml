<ui:FluentWindow x:Class="LumenPomodoro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:pages="clr-namespace:LumenPomodoro.Views.Pages"
        mc:Ignorable="d"
        Title="Lumen Pomodoro" Width="520" Height="640" MinHeight="520"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        Icon="pack://application:,,,/LOGO.png">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/CustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource SpotifyCanvasBrush}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Lumen Pomodoro"
                       Margin="14,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource SpotifyTextSecondaryBrush}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Width="46" Height="36"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="MinimizeButton_Click"
                        ToolTip="最小化">
                    <TextBlock Text="-" FontSize="16" VerticalAlignment="Center" Foreground="{DynamicResource SpotifyTextSecondaryBrush}" />
                </Button>
                <Button Width="46" Height="36"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="MaximizeButton_Click"
                        ToolTip="最大化">
                    <TextBlock Text="□" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource SpotifyTextSecondaryBrush}" />
                </Button>
                <Button Width="46" Height="36"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CloseButton_Click"
                        ToolTip="关闭">
                    <TextBlock Text="×" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource SpotifyTextSecondaryBrush}" />
                </Button>
            </StackPanel>
        </Grid>

        <ui:NavigationView Grid.Row="1" x:Name="NavView" PaneDisplayMode="Bottom" Transition="SlideBottom">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="计时器" Icon="{ui:SymbolIcon Timer24}" TargetPageType="{x:Type pages:TimerPage}" />
                <ui:NavigationViewItem Content="任务" Icon="{ui:SymbolIcon TaskListSquareLtr24}" TargetPageType="{x:Type pages:TasksPage}" />
                <ui:NavigationViewItem Content="统计" Icon="{ui:SymbolIcon ChartMultiple24}" TargetPageType="{x:Type pages:StatsPage}" />
                <ui:NavigationViewItem Content="设置" Icon="{ui:SymbolIcon Settings24}" TargetPageType="{x:Type pages:SettingsPage}" />
            </ui:NavigationView.MenuItems>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
