<UserControl x:Class="LumenPomodoro.Controls.TaskDonutChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Canvas x:Name="DonutCanvas" Grid.Column="0" Width="120" Height="120" Margin="0,0,16,0" />
        <StackPanel x:Name="LegendPanel" Grid.Column="1" VerticalAlignment="Center" />
    </Grid>
</UserControl>
